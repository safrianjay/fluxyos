rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidBaseRecord(data) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp is timestamp;
    }

    function isValidBaseRecordUpdate(data, existingData) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp == existingData.timestamp;
    }

    function isValidTransactionRecordUpdate(data, existingData) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled', 'Voided']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp is timestamp
        && (!('created_at' in data) || data.created_at == existingData.created_at)
        && (!('updated_at' in data) || data.updated_at == request.time)
        && (!('updated_by' in data) || data.updated_by == request.auth.uid)
        && (!('is_voided' in data) || data.is_voided is bool)
        && (!('voided_at' in data) || data.voided_at == request.time)
        && (!('voided_by' in data) || data.voided_by == request.auth.uid)
        && (!('void_reason' in data) || (data.void_reason is string && data.void_reason.size() > 0 && data.void_reason.size() <= 500))
        && (!(data.status == 'Voided') || (
          data.is_voided == true
          && data.voided_at == request.time
          && data.voided_by == request.auth.uid
          && data.void_reason is string
          && data.void_reason.size() > 0
          && data.void_reason.size() <= 500
        ));
    }

    function isValidAICaptureMetadata(data) {
      return (!('source' in data) || data.source in ['bill_scan', 'transaction_scan', 'subscription_scan', 'bank_statement_import'])
        && (!('created_via' in data) || data.created_via in ['ai_bill_capture', 'ai_transaction_capture', 'ai_subscription_capture'])
        && (!('extraction_status' in data) || data.extraction_status == 'reviewed')
        && (!('extraction_source' in data) || data.extraction_source is string)
        && (!('extraction_confidence' in data) || data.extraction_confidence == null || data.extraction_confidence is number)
        && (!('extraction_warnings' in data) || data.extraction_warnings is list)
        && (!('document_type' in data) || data.document_type is string)
        && (!('invoice_number' in data) || data.invoice_number == null || data.invoice_number is string)
        && (!('invoice_date' in data) || data.invoice_date is timestamp)
        && (!('raw_text_preview' in data) || data.raw_text_preview == null || (data.raw_text_preview is string && data.raw_text_preview.size() <= 500))
        && (!('source_file_name' in data) || data.source_file_name == null || data.source_file_name is string)
        && (!('source_file_mime_type' in data) || data.source_file_mime_type == null || data.source_file_mime_type is string)
        && (!('source_file_size_bytes' in data) || data.source_file_size_bytes == null || data.source_file_size_bytes is number)
        && (!('payment_reference' in data) || data.payment_reference == null || data.payment_reference is string)
        && (!('notes' in data) || data.notes == null || data.notes is string)
        && (!('billing_cycle' in data) || data.billing_cycle in ['monthly', 'annual', 'weekly', 'quarterly', 'unknown'])
        && (!('bank_statement_import_id' in data) || data.bank_statement_import_id is string)
        && (!('bank_statement_row_id' in data) || data.bank_statement_row_id is string)
        && (!('imported_at' in data) || data.imported_at == null || data.imported_at is timestamp)
        && (!('bank_account_id' in data) || data.bank_account_id == null || data.bank_account_id is string);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll([
          'actor_uid',
          'action',
          'target_collection',
          'target_id',
          'source',
          'created_at'
        ])
        && data.actor_uid == request.auth.uid
        && data.action is string
        && data.action.size() > 0
        && data.action.size() <= 80
        && data.target_collection in [
          'transactions',
          'bills',
          'subscriptions',
          'vendors',
          'budgets',
          'budget_allocations',
          'integrations',
          'exports',
          'report_exports',
          'users',
          'onboarding',
          'bank_accounts',
          'bank_balance_snapshots',
          'bank_statement_imports',
          'documents',
          'billing',
          'billing_payment_requests',
          'payment_verifications',
          'accounting_mappings',
          'invoices'
        ]
        && data.target_id is string
        && data.target_id.size() <= 160
        && data.source in ['dashboard', 'ai', 'integration', 'system', 'onboarding']
        && data.created_at == request.time;
    }

    // Internal-console outreach leads (Sales Leads → Outreach subpage). Manually
    // entered prospects the team sends the bilingual meeting-reminder to.
    // MVP_INTERNAL_ONLY_TEMPORARY — open + field-validated like internal_digest_jobs;
    // the actual email send is gated by the send-lead-outreach function token.
    function isValidOutreachLead(data) {
      return data.keys().hasOnly([
          'name', 'gender', 'email', 'role', 'company', 'meeting_at',
          'status', 'last_sent_at', 'created_at', 'updated_at'
        ])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 120
        && data.gender in ['male', 'female']
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.status in ['new', 'sent', 'meeting_booked', 'closed']
        && data.meeting_at is timestamp
        && (!('role' in data) || (data.role is string && data.role.size() <= 120))
        && (!('company' in data) || (data.company is string && data.company.size() <= 160))
        && (!('last_sent_at' in data) || data.last_sent_at is timestamp)
        && data.created_at is timestamp
        && data.updated_at is timestamp;
    }

    // Accounting Center (Phase 1) — saved category/type → account mappings.
    // Strings/enums only. No money, no row-level financial data, no formatted
    // currency. See docs/PROJECT_BACKGROUND.md §4 (Accounting mappings).
    function isValidAccountingMapping(data) {
      return data.keys().hasOnly([
          'source_type',
          'source_value',
          'target_account_code',
          'target_account_name',
          'target_account_type',
          'confidence',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasAll([
          'source_type',
          'source_value',
          'target_account_code',
          'target_account_name',
          'target_account_type',
          'confidence',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.source_type in ['transaction_category', 'transaction_type']
        && data.source_value is string
        && data.source_value.size() > 0
        && data.source_value.size() <= 60
        && data.target_account_code is string
        && data.target_account_code.size() > 0
        && data.target_account_code.size() <= 12
        && data.target_account_name is string
        && data.target_account_name.size() > 0
        && data.target_account_name.size() <= 80
        && data.target_account_type in ['asset', 'liability', 'equity', 'revenue', 'expense', 'contra_revenue', 'contra_expense']
        && data.confidence in ['system_default', 'user_confirmed', 'ai_suggested']
        && data.status in ['active', 'archived'];
    }

    function isValidAccountingMappingCreate(data) {
      return isValidAccountingMapping(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidAccountingMappingUpdate(data, existingData) {
      return isValidAccountingMapping(data)
        && data.source_type == existingData.source_type
        && data.source_value == existingData.source_value
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    // Owner-scoped 3-day trial / billing access doc (users/{uid}/billing/access).
    // Status enums only — no secrets, no formatted currency strings.
    function isValidBillingAccess(data) {
      return (!('access_status' in data) || data.access_status in [
          'trial_not_started', 'trial_active', 'trial_expiring', 'trial_expired',
          'payment_pending', 'payment_submitted', 'payment_verified', 'active', 'suspended'
        ])
        && (!('payment_status' in data) || data.payment_status in [
          'not_started', 'pending', 'submitted', 'under_review', 'verified', 'rejected'
        ])
        && (!('account_status' in data) || data.account_status in ['trial', 'active', 'suspended'])
        && (!('trial_duration_days' in data) || data.trial_duration_days is number)
        && (!('plan_id' in data) || data.plan_id == null
          || (data.plan_id is string && data.plan_id.size() <= 40));
    }

    // Owner-scoped manual payment proof (users/{uid}/payment_verifications/{id}).
    // Raw-integer amounts only; no card data / secrets.
    function isValidPaymentVerification(data) {
      return data.amount is number && data.amount >= 0 && data.amount <= 999999999999
        && data.currency == 'IDR'
        && data.status in ['submitted', 'under_review', 'verified', 'rejected']
        && (!('payment_method' in data) || data.payment_method in ['bank_transfer', 'manual', 'other'])
        && (!('billing_period' in data) || data.billing_period == null
          || data.billing_period in ['monthly', 'annual', 'custom'])
        && (!('proof_file_name' in data) || data.proof_file_name == null
          || (data.proof_file_name is string && data.proof_file_name.size() <= 240))
        && (!('submitted_note' in data) || data.submitted_note == null
          || (data.submitted_note is string && data.submitted_note.size() <= 500));
    }

    function isValidBillingPlan(planId) {
      return planId in ['trial', 'starter', 'core', 'growth', 'enterprise'];
    }

    function isValidBillingPlanName(planId, planName) {
      return (planId == 'trial' && planName == 'Trial')
        || (planId == 'starter' && planName == 'Starter')
        || (planId == 'core' && planName == 'Core Ops')
        || (planId == 'growth' && planName == 'Growth Engine')
        || (planId == 'enterprise' && planName == 'Enterprise AI');
    }

    // Voucher discount snapshot on a payment request. The fields are optional
    // (old cached clients omit them); absent/null means no voucher. When a
    // voucher IS applied, hasValidPaymentRequestVoucher() re-derives every
    // value from the canonical voucher doc, so this helper alone is never
    // trusted for a discount.
    function voucherDiscountOf(data) {
      return ('voucher_discount_amount' in data) && data.voucher_discount_amount != null
        ? data.voucher_discount_amount
        : 0;
    }

    // Self-serve plan subtotals. Mirrors `BILLING_PLANS` in assets/js/billing-config.js
    // (monthly = `monthly`; annually = `annualMonthlyEquivalent` × 12). Enterprise AI
    // is sales-led — it has NO self-serve amount, so no enterprise branch exists here
    // and a self-serve enterprise payment request is rejected.
    function isValidBillingAmounts(data) {
      return (
          (data.plan_id == 'starter' && data.billing_frequency == 'monthly' && data.subtotal_amount == 1290000)
          || (data.plan_id == 'starter' && data.billing_frequency == 'annually' && data.subtotal_amount == 11880000)
          || (data.plan_id == 'core' && data.billing_frequency == 'monthly' && data.subtotal_amount == 3490000)
          || (data.plan_id == 'core' && data.billing_frequency == 'annually' && data.subtotal_amount == 33480000)
          || (data.plan_id == 'growth' && data.billing_frequency == 'monthly' && data.subtotal_amount == 6990000)
          || (data.plan_id == 'growth' && data.billing_frequency == 'annually' && data.subtotal_amount == 67080000)
        )
        // PPN applies to the voucher-discounted subtotal. Every plan subtotal is
        // a multiple of 10.000 and discounts are integer percents, so the
        // integer math here is exact (no truncation) and matches the client.
        && data.estimated_tax_amount == (data.subtotal_amount - voucherDiscountOf(data)) * 11 / 100;
    }

    function isValidBillingFrequency(frequency) {
      return frequency == null || frequency in ['monthly', 'annually'];
    }

    function isValidBillingSubscription(data) {
      return data.keys().hasAll([
          'plan_id',
          'plan_name',
          'status',
          'billing_frequency',
          'current_payment_request_id',
          'trial_started_at',
          'trial_ends_at',
          'current_period_start',
          'current_period_end',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'plan_id',
          'plan_name',
          'status',
          'billing_frequency',
          'current_payment_request_id',
          'trial_started_at',
          'trial_ends_at',
          'current_period_start',
          'current_period_end',
          'updated_at'
        ])
        && isValidBillingPlan(data.plan_id)
        && isValidBillingPlanName(data.plan_id, data.plan_name)
        && data.status in ['trialing', 'awaiting_payment', 'pending_verification', 'active', 'cancel_scheduled', 'past_due', 'expired', 'payment_failed']
        && isValidBillingFrequency(data.billing_frequency)
        && (data.current_payment_request_id == null || (data.current_payment_request_id is string && data.current_payment_request_id.size() <= 160))
        && (data.trial_started_at == null || data.trial_started_at is timestamp)
        && (data.trial_ends_at == null || data.trial_ends_at is timestamp)
        && (data.current_period_start == null || data.current_period_start is timestamp)
        && (data.current_period_end == null || data.current_period_end is timestamp)
        && data.updated_at == request.time;
    }

    function isValidBillingPaymentRequest(data) {
      return data.keys().hasAll([
          'plan_id',
          'plan_name',
          'billing_frequency',
          'subtotal_amount',
          'estimated_tax_amount',
          'total_amount',
          'currency',
          'payment_method',
          'payment_status',
          'provider',
          'provider_payment_id',
          'provider_invoice_url',
          'submitted_at',
          'verified_at',
          'failed_at',
          'expires_at',
          'user_confirmed_payment_at',
          'submitted_for_verification_at',
          'proof_document_id',
          'proof_file_name',
          'proof_uploaded_at',
          'created_at',
          'updated_at',
          'prev_plan_id',
          'prev_plan_name',
          'prev_status',
          'prev_billing_frequency'
        ])
        // Voucher snapshot fields are allowed but NOT required (hasOnly, not
        // hasAll) so pre-voucher cached clients keep working. The new client
        // always writes all four (null when no voucher is applied).
        && data.keys().hasOnly([
          'plan_id',
          'plan_name',
          'billing_frequency',
          'subtotal_amount',
          'estimated_tax_amount',
          'total_amount',
          'currency',
          'payment_method',
          'payment_status',
          'provider',
          'provider_payment_id',
          'provider_invoice_url',
          'submitted_at',
          'verified_at',
          'failed_at',
          'expires_at',
          'user_confirmed_payment_at',
          'submitted_for_verification_at',
          'proof_document_id',
          'proof_file_name',
          'proof_uploaded_at',
          'created_at',
          'updated_at',
          'prev_plan_id',
          'prev_plan_name',
          'prev_status',
          'prev_billing_frequency',
          'voucher_id',
          'voucher_code',
          'voucher_discount_percent',
          'voucher_discount_amount'
        ])
        && data.plan_id in ['starter', 'core', 'growth', 'enterprise']
        && isValidBillingPlanName(data.plan_id, data.plan_name)
        && data.billing_frequency in ['monthly', 'annually']
        && data.subtotal_amount is number
        && data.subtotal_amount > 0
        && data.estimated_tax_amount is number
        && data.estimated_tax_amount >= 0
        && data.total_amount is number
        && data.total_amount == data.subtotal_amount - voucherDiscountOf(data) + data.estimated_tax_amount
        && isValidBillingAmounts(data)
        && data.currency == 'IDR'
        && data.payment_method in ['qris', 'va', 'card', 'invoice']
        // QRIS starts as awaiting_payment (pay the QR first); other methods submit
        // for verification immediately. verified/failed/expired stay server-owned.
        && data.payment_status in ['awaiting_payment', 'pending_verification']
        && data.provider == 'manual'
        && data.provider_payment_id == null
        && data.provider_invoice_url == null
        && data.submitted_at == request.time
        && data.verified_at == null
        && data.failed_at == null
        && data.expires_at == null
        && data.user_confirmed_payment_at == null
        && data.submitted_for_verification_at == null
        && data.proof_document_id == null
        && data.proof_file_name == null
        && data.proof_uploaded_at == null
        && data.created_at == request.time
        && data.updated_at == request.time
        // Prior-subscription snapshot (used to safely restore state on cancel).
        && (data.prev_plan_id == null || data.prev_plan_id in ['trial', 'starter', 'core', 'growth', 'enterprise'])
        && (data.prev_plan_name == null || (data.prev_plan_name is string && data.prev_plan_name.size() <= 60))
        && (data.prev_status == null || data.prev_status in ['trialing', 'awaiting_payment', 'pending_verification', 'active', 'past_due', 'expired', 'payment_failed'])
        && (data.prev_billing_frequency == null || data.prev_billing_frequency in ['monthly', 'annually']);
    }

    // The prior-subscription snapshot stored on a new payment request must mirror
    // the user's ACTUAL subscription at creation time (read pre-batch via get()),
    // so it can never be forged to later restore an elevated/unpaid plan on cancel.
    function hasValidPaymentRequestPrevSnapshot(userId, data) {
      return (
          !exists(/databases/$(database)/documents/users/$(userId)/billing_subscription/current)
          && data.prev_plan_id == null
          && data.prev_plan_name == null
          && data.prev_status == null
          && data.prev_billing_frequency == null
        ) || (
          exists(/databases/$(database)/documents/users/$(userId)/billing_subscription/current)
          && data.prev_plan_id == get(/databases/$(database)/documents/users/$(userId)/billing_subscription/current).data.plan_id
          && data.prev_plan_name == get(/databases/$(database)/documents/users/$(userId)/billing_subscription/current).data.plan_name
          && data.prev_status == get(/databases/$(database)/documents/users/$(userId)/billing_subscription/current).data.status
          && data.prev_billing_frequency == get(/databases/$(database)/documents/users/$(userId)/billing_subscription/current).data.billing_frequency
        );
    }

    // True when the payment request carries no voucher at all (fields absent
    // for pre-voucher cached clients, or all-null for the current client).
    // Mixed null/non-null voucher fields fail both this and the applied branch.
    function hasNoVoucherFields(data) {
      return (!('voucher_id' in data) || data.voucher_id == null)
        && (!('voucher_code' in data) || data.voucher_code == null)
        && (!('voucher_discount_percent' in data) || data.voucher_discount_percent == null)
        && (!('voucher_discount_amount' in data) || data.voucher_discount_amount == null);
    }

    // Server-enforced voucher redemption. The discount on a payment request is
    // only accepted when, in the SAME commit:
    //   1. the canonical voucher doc (voucher_codes/{CODE}, read pre-commit via
    //      get()) is active, inside its validity window, allows the selected
    //      plan + billing frequency, and still has redemption slots left;
    //   2. the snapshot percent equals the voucher's discount_value and the
    //      discount amount is recomputed here (subtotal * percent / 100 —
    //      integer-exact, see isValidBillingAmounts);
    //   3. the voucher's redemption_count is incremented by exactly 1
    //      (checked via getAfter against the pre-commit value); and
    //   4. a voucher_redemptions/{paymentRequestId} doc for this user + voucher
    //      is created in the same commit (its own create rule mirrors the
    //      amounts back against this payment request via getAfter).
    // A client editing browser JS cannot forge any of these: the rules engine
    // recomputes the price from the voucher doc it reads itself.
    function hasValidPaymentRequestVoucher(userId, requestId, data) {
      return hasNoVoucherFields(data)
        || hasAppliedPaymentRequestVoucher(userId, requestId, data);
    }

    // `let` bindings keep the expression count low (rules evaluate at most
    // 1000 expressions per request; repeating the full get() path in every
    // condition blows that budget on this already-large create rule). A null
    // voucher_id or missing voucher doc makes the binding error → deny, which
    // is the correct outcome for mixed-null fields or unknown codes.
    function hasAppliedPaymentRequestVoucher(userId, requestId, data) {
      let voucher = get(/databases/$(database)/documents/voucher_codes/$(data.voucher_id)).data;
      let voucherAfter = getAfter(/databases/$(database)/documents/voucher_codes/$(data.voucher_id)).data;
      let redemptionAfter = getAfter(/databases/$(database)/documents/voucher_redemptions/$(requestId)).data;
      return data.voucher_id is string
        && data.voucher_id.matches('^[A-Z0-9_-]{4,32}$')
        && data.voucher_code == data.voucher_id
        && data.voucher_discount_percent is int
        && data.voucher_discount_percent >= 1
        && data.voucher_discount_percent <= 100
        && voucher.status == 'active'
        && voucher.discount_type == 'percentage'
        && data.voucher_discount_percent == voucher.discount_value
        && data.voucher_discount_amount == data.subtotal_amount * data.voucher_discount_percent / 100
        && (voucher.valid_from == null || voucher.valid_from <= request.time)
        && (voucher.valid_until == null || voucher.valid_until >= request.time)
        && (voucher.allowed_plan_ids == null || data.plan_id in voucher.allowed_plan_ids)
        && (voucher.allowed_billing_frequencies == null || data.billing_frequency in voucher.allowed_billing_frequencies)
        && (voucher.max_redemptions == null || voucher.redemption_count < voucher.max_redemptions)
        && voucherAfter.redemption_count == voucher.redemption_count + 1
        && redemptionAfter.user_id == userId
        && redemptionAfter.voucher_id == data.voucher_id;
    }

    // Owner-driven transition: a QRIS request moves awaiting_payment ->
    // pending_verification after the user confirms payment. Only the lifecycle
    // + optional proof-reference fields may change; amounts/plan/method are
    // immutable (guaranteed by the affectedKeys allow-list). The client can
    // never write verified/failed/expired here.
    function isValidPaymentRequestVerificationSubmit(prev, next) {
      return prev.payment_status == 'awaiting_payment'
        && next.payment_status == 'pending_verification'
        && next.diff(prev).affectedKeys().hasOnly([
          'payment_status',
          'user_confirmed_payment_at',
          'submitted_for_verification_at',
          'proof_document_id',
          'proof_file_name',
          'proof_uploaded_at',
          'updated_at'
        ])
        && next.user_confirmed_payment_at is timestamp
        && next.submitted_for_verification_at == request.time
        && next.updated_at == request.time
        && (
          (next.proof_document_id == null && next.proof_file_name == null && next.proof_uploaded_at == null)
          || (next.proof_document_id is string && next.proof_document_id.size() <= 160
            && next.proof_file_name is string && next.proof_file_name.size() <= 240
            && next.proof_uploaded_at is timestamp)
        );
    }

    // Owner-driven cancel: an in-flight QRIS request moves
    // awaiting_payment|pending_verification -> canceled. Only the lifecycle
    // status + updated_at may change; amounts/plan/method stay immutable
    // (guaranteed by the affectedKeys allow-list). verified/failed/expired stay
    // server-owned and can never be set here.
    function isValidPaymentRequestCancel(prev, next) {
      return (prev.payment_status == 'awaiting_payment' || prev.payment_status == 'pending_verification')
        && next.payment_status == 'canceled'
        && next.diff(prev).affectedKeys().hasOnly([
          'payment_status',
          'updated_at'
        ])
        && next.updated_at == request.time;
    }

    function isCheckoutSubscriptionWrite(userId, data) {
      return data.status == 'pending_verification'
        && data.plan_id in ['starter', 'core', 'growth', 'enterprise']
        && data.billing_frequency in ['monthly', 'annually']
        && data.current_payment_request_id is string
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.plan_id == data.plan_id
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.billing_frequency == data.billing_frequency
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.payment_status == 'pending_verification';
    }

    function hasRecentBillingPeriodStart(data) {
      return data.current_period_start is timestamp
        && data.current_period_start <= request.time
        && data.current_period_start >= request.time - duration.value(10, 'm');
    }

    function hasInternalVerifiedBillingPeriodStart(userId, data) {
      return get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_verified_at is timestamp
        && data.current_period_start == get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_verified_at;
    }

    function hasValidBillingPeriodWindow(data) {
      return data.current_period_start is timestamp
        && data.current_period_end is timestamp
        && data.current_period_end > data.current_period_start
        && (
          (data.billing_frequency == 'monthly'
            && data.current_period_end <= data.current_period_start + duration.value(32, 'd'))
          || (data.billing_frequency == 'annually'
            && data.current_period_end >= data.current_period_start + duration.value(360, 'd')
            && data.current_period_end <= data.current_period_start + duration.value(367, 'd'))
        );
    }

    function hasValidVerifiedBillingPeriod(userId, data) {
      return hasValidBillingPeriodWindow(data)
        && (hasInternalVerifiedBillingPeriodStart(userId, data) || hasRecentBillingPeriodStart(data));
    }

    function hasValidActiveReconcileFields(userId, prev, data) {
      return data.diff(prev).affectedKeys().hasOnly(['status', 'updated_at'])
        || (data.diff(prev).affectedKeys().hasOnly(['status', 'current_period_start', 'current_period_end', 'updated_at'])
          && prev.current_period_end == null
          && hasValidVerifiedBillingPeriod(userId, data));
    }

    // Owner carries a reviewer's verify/reject decision from the open
    // internal_users index into their canonical subscription. Verified payments
    // may also stamp current_period_start/current_period_end from the verified
    // billing frequency so settings can show the next billing date.
    // MVP/UX-only: internal_users is the credential-gated ops index; a trusted
    // backend should own this in production.
    function isInternalReviewReconcile(userId, prev, data) {
      return exists(/databases/$(database)/documents/internal_users/$(userId))
        && (
          // A verified payment is a definitive grant: promote to active from any
          // not-yet-active state (incl. expired/trialing). No updated_at race —
          // the automatic trial-expiry write bumps prev.updated_at after the
          // manual review, which must not strand an approved user.
          (data.status == 'active'
            && prev.status in ['pending_verification', 'awaiting_payment', 'expired', 'trialing']
            && hasValidActiveReconcileFields(userId, prev, data)
            && get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_status == 'verified')
          // Rejection only fails an in-flight payment and must be newer than the
          // subscription's own last write (never clobber a fresh retry).
          || (data.status == 'payment_failed'
            && data.diff(prev).affectedKeys().hasOnly(['status', 'updated_at'])
            && (prev.status == 'pending_verification' || prev.status == 'awaiting_payment')
            && get(/databases/$(database)/documents/internal_users/$(userId)).data.updated_at > prev.updated_at
            && get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_status == 'rejected')
        );
    }

    function isActiveBillingPeriodBackfill(userId, prev, data) {
      return exists(/databases/$(database)/documents/internal_users/$(userId))
        && prev.status == 'active'
        && data.status == 'active'
        && prev.current_period_end == null
        && get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_status == 'verified'
        && data.diff(prev).affectedKeys().hasOnly(['current_period_start', 'current_period_end', 'updated_at'])
        && hasValidVerifiedBillingPeriod(userId, data);
    }

    // QRIS checkout: subscription moves to awaiting_payment alongside an
    // awaiting_payment request (cross-checked in the same commit).
    function isCheckoutAwaitingPaymentWrite(userId, data) {
      return data.status == 'awaiting_payment'
        && data.plan_id in ['starter', 'core', 'growth', 'enterprise']
        && data.billing_frequency in ['monthly', 'annually']
        && data.current_payment_request_id is string
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.plan_id == data.plan_id
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.billing_frequency == data.billing_frequency
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.payment_status == 'awaiting_payment';
    }

    // Owner cancels an in-flight payment: the subscription reverts from
    // awaiting_payment|pending_verification back to its trial state (trialing if
    // the trial is still live, expired if it already lapsed), dropping the
    // unpaid plan and clearing the payment request link. Cross-checked against
    // the linked request being canceled in the SAME commit, so access can never
    // silently revert to trial without the request actually being voided.
    function isCancelPaymentRevert(userId, prev, data) {
      return (prev.status == 'awaiting_payment' || prev.status == 'pending_verification')
        && prev.current_payment_request_id is string
        && data.plan_id == 'trial'
        && data.plan_name == 'Trial'
        && data.billing_frequency == null
        && data.current_payment_request_id == null
        && data.current_period_start == null
        && data.current_period_end == null
        && data.trial_started_at == prev.trial_started_at
        && data.trial_ends_at == prev.trial_ends_at
        && (
          (data.status == 'trialing' && (prev.trial_ends_at == null || prev.trial_ends_at >= request.time))
          || (data.status == 'expired' && prev.trial_ends_at is timestamp && prev.trial_ends_at < request.time)
        )
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(prev.current_payment_request_id)).data.payment_status == 'canceled';
    }

    // Owner cancels an in-flight payment that was started while ALREADY on a paid
    // plan (e.g. an upgrade attempt): the subscription is restored to that prior
    // active plan rather than dropped to trial. The restored plan/frequency must
    // match the snapshot captured on the canceled request (which itself was bound
    // to the real prior subscription at create time), the billing period is
    // preserved unchanged and must be a valid window, and the linked request must
    // be canceled in the same commit. This grants 'active' only when the user
    // genuinely held it — never an escalation.
    function isCancelRestoreActive(userId, prev, data) {
      return (prev.status == 'awaiting_payment' || prev.status == 'pending_verification')
        && prev.current_payment_request_id is string
        && data.status == 'active'
        && data.plan_id in ['starter', 'core', 'growth', 'enterprise']
        && data.billing_frequency in ['monthly', 'annually']
        && data.current_payment_request_id == null
        && data.trial_started_at == prev.trial_started_at
        && data.trial_ends_at == prev.trial_ends_at
        && data.current_period_start == prev.current_period_start
        && data.current_period_end == prev.current_period_end
        && (
          (data.current_period_start == null && data.current_period_end == null)
          || hasValidBillingPeriodWindow(data)
        )
        && data.plan_id == getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(prev.current_payment_request_id)).data.prev_plan_id
        && data.plan_name == getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(prev.current_payment_request_id)).data.prev_plan_name
        && data.billing_frequency == getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(prev.current_payment_request_id)).data.prev_billing_frequency
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(prev.current_payment_request_id)).data.prev_status == 'active'
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(prev.current_payment_request_id)).data.payment_status == 'canceled';
    }

    // Owner cancels renewal on an active subscription: status moves
    // active -> cancel_scheduled (access kept until period end). Reactivate is the
    // inverse (cancel_scheduled -> active). Only the lifecycle status changes, and
    // neither is an escalation — the user already holds the paid entitlement.
    function isCancelRenewalWrite(prev, data) {
      return prev.status == 'active'
        && data.status == 'cancel_scheduled'
        && data.diff(prev).affectedKeys().hasOnly(['status', 'updated_at'])
        && data.updated_at == request.time;
    }

    function isReactivateRenewalWrite(prev, data) {
      return prev.status == 'cancel_scheduled'
        && data.status == 'active'
        && data.diff(prev).affectedKeys().hasOnly(['status', 'updated_at'])
        && data.updated_at == request.time;
    }

    function isTrialSubscriptionCreate(data) {
      return data.status == 'trialing'
        && data.plan_id == 'trial'
        && data.plan_name == 'Trial'
        && data.billing_frequency == null
        && data.current_payment_request_id == null
        && data.trial_started_at is timestamp
        && data.trial_ends_at is timestamp
        && data.trial_started_at <= request.time
        && data.trial_ends_at == data.trial_started_at + duration.value(3, 'd')
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/onboarding/progress)
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)/onboarding/progress).data.onboarding_completed == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)/onboarding/progress).data.onboarding_exempt == true);
    }

    function isLegacyBillingMigration(userId, data) {
      return exists(/databases/$(database)/documents/users/$(userId)/billing/access)
        && data.trial_started_at == get(/databases/$(database)/documents/users/$(userId)/billing/access).data.trial_started_at
        && data.trial_ends_at == get(/databases/$(database)/documents/users/$(userId)/billing/access).data.trial_ends_at
        && (
          (data.status == 'active'
            && (get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status in ['active', 'payment_verified']
              || get(/databases/$(database)/documents/users/$(userId)/billing/access).data.payment_status == 'verified'))
          || (data.status == 'pending_verification'
            && (get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status == 'payment_submitted'
              || get(/databases/$(database)/documents/users/$(userId)/billing/access).data.payment_status in ['submitted', 'under_review']))
          || (data.status == 'payment_failed'
            && get(/databases/$(database)/documents/users/$(userId)/billing/access).data.payment_status == 'rejected')
          || (data.status == 'expired'
            && get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status == 'trial_expired')
          || (data.status == 'trialing'
            && get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status in ['trial_active', 'trial_expiring'])
        );
    }

    // Internal Operations Console (Phase 1 MVP). Operational metadata only —
    // never financial ledger data. See the open `internal_*` matches below.
    function isValidInternalUser(data) {
      return (!('account_status' in data) || data.account_status in [
          'registered', 'kyc_incomplete', 'kyc_submitted', 'kyc_approved',
          'kyc_rejected', 'payment_pending', 'payment_submitted',
          'payment_verified', 'active', 'suspended'
        ])
        && (!('kyc_status' in data) || data.kyc_status in [
          'not_started', 'in_progress', 'submitted', 'needs_revision',
          'approved', 'rejected'
        ])
        && (!('payment_status' in data) || data.payment_status in [
          'not_required', 'pending', 'submitted', 'under_review',
          'verified', 'rejected', 'expired'
        ])
        && (!('payment_amount' in data) || data.payment_amount == null
          || (data.payment_amount is number && data.payment_amount >= 0 && data.payment_amount <= 999999999999))
        && (!('access_status' in data) || data.access_status in [
          'trial_not_started', 'trial_active', 'trial_expiring', 'trial_expired',
          'payment_pending', 'payment_submitted', 'payment_verified', 'active', 'suspended'
        ])
        && (!('trial_days_remaining' in data) || data.trial_days_remaining == null
          || (data.trial_days_remaining is number && data.trial_days_remaining >= 0))
        && (!('payment_proof_file_name' in data) || data.payment_proof_file_name == null
          || (data.payment_proof_file_name is string && data.payment_proof_file_name.size() <= 240))
        && (!('last_internal_note' in data) || data.last_internal_note == null
          || (data.last_internal_note is string && data.last_internal_note.size() <= 500))
        && (!('email' in data) || data.email == null
          || (data.email is string && data.email.size() <= 160))
        && (!('business_name' in data) || data.business_name == null
          || (data.business_name is string && data.business_name.size() <= 160));
    }

    function isValidDocumentMetadata(data) {
      return data.keys().hasAll([
          'file_name',
          'file_mime_type',
          'file_size',
          'storage_path',
          'document_role',
          'source_context',
          'upload_status',
          'extraction_status',
          'review_status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'file_name',
          'file_mime_type',
          'file_size',
          'storage_path',
          'document_role',
          'source_context',
          'target_collection',
          'target_id',
          'upload_status',
          'extraction_status',
          'review_status',
          'created_at',
          'updated_at'
        ])
        && data.file_name is string
        && data.file_name.size() > 0
        && data.file_name.size() <= 240
        && data.file_mime_type in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf']
        && data.file_size is number
        && data.file_size > 0
        && data.file_size <= 5 * 1024 * 1024
        && data.storage_path is string
        && data.storage_path.size() <= 400
        && data.document_role in ['receipt', 'invoice', 'payment_proof', 'revenue_proof', 'unknown_finance_document']
        && data.source_context in ['transaction', 'revenue', 'bill', 'subscription', 'payment']
        && (!('target_collection' in data) || data.target_collection == null || data.target_collection in ['transactions', 'bills', 'subscriptions'])
        && (!('target_id' in data) || data.target_id is string)
        && data.upload_status in ['pending', 'uploaded', 'failed', 'removed']
        && data.extraction_status in ['not_requested', 'pending', 'completed', 'failed']
        && data.review_status in ['not_required', 'needs_review', 'confirmed', 'rejected']
        && data.created_at is timestamp
        && data.updated_at is timestamp;
    }

    function hasTrialStorageEntitlement(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/billing_subscription/current)
        && (
          get(/databases/$(database)/documents/users/$(userId)/billing_subscription/current).data.plan_id == 'trial'
          || get(/databases/$(database)/documents/users/$(userId)/billing_subscription/current).data.status in [
            'trialing',
            'awaiting_payment',
            'pending_verification',
            'payment_failed',
            'expired'
          ]
        );
    }

    function respectsTrialStorageSingleFileLimit(userId, data) {
      return !hasTrialStorageEntitlement(userId)
        || data.file_size <= 5 * 1024 * 1024;
    }

    function isValidAttachedDocuments(data) {
      return !('attached_documents' in data)
        || (data.attached_documents is list && data.attached_documents.size() <= 20);
    }

    function isValidAIChat(data) {
      return data.keys().hasAll([
          'title',
          'summary',
          'last_message_preview',
          'intent',
          'source',
          'created_at',
          'updated_at',
          'last_activity_at',
          'expires_at',
          'message_count',
          'status'
        ])
        && data.keys().hasOnly([
          'title',
          'summary',
          'last_message_preview',
          'intent',
          'source',
          'created_at',
          'updated_at',
          'last_activity_at',
          'expires_at',
          'message_count',
          'status',
          'deleted_at'
        ])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.summary is string
        && data.summary.size() <= 500
        && data.last_message_preview is string
        && data.last_message_preview.size() <= 500
        && data.intent is string
        && data.intent.size() > 0
        && data.intent.size() <= 80
        && data.source == 'ai_command_center'
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && data.last_activity_at is timestamp
        && data.expires_at is timestamp
        && data.message_count is number
        && data.message_count >= 0
        && data.message_count <= 500
        && data.status in ['active', 'deleted']
        && (!('deleted_at' in data) || data.deleted_at is timestamp);
    }

    function isValidAIChatCreate(data) {
      return isValidAIChat(data)
        && data.created_at == request.time
        && data.updated_at == request.time
        && data.last_activity_at == request.time
        && data.status == 'active'
        && !('deleted_at' in data);
    }

    function isValidAIChatUpdate(data, existingData) {
      return isValidAIChat(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time
        && data.last_activity_at is timestamp;
    }

    function isValidAIChatMessage(data) {
      return data.keys().hasAll([
          'role',
          'content',
          'created_at',
          'expires_at'
        ])
        && data.keys().hasOnly([
          'role',
          'content',
          'structured_answer',
          'attachments',
          'created_at',
          'expires_at'
        ])
        && data.role in ['user', 'assistant', 'system']
        && data.content is string
        && data.content.size() <= 10000
        && (!('structured_answer' in data) || data.structured_answer == null || data.structured_answer is map)
        && (!('attachments' in data) || data.attachments is list)
        && data.created_at == request.time
        && data.expires_at is timestamp;
    }

    function isValidTrialAIUsage(data) {
      return data.keys().hasAll([
          'metric',
          'scope',
          'count',
          'limit'
        ])
        && data.keys().hasOnly([
          'metric',
          'scope',
          'count',
          'limit'
        ])
        && data.metric == 'ai_chat_requests'
        && data.scope == 'trial'
        && data.limit == 3
        && data.count is number
        && data.count >= 1
        && data.count <= 3;
    }

    function isValidTrialAIUsageCreate(limitId, data) {
      return limitId == 'ai_chat_trial'
        && isValidTrialAIUsage(data)
        && data.count == 1;
    }

    function isValidTrialAIUsageUpdate(limitId, data, existingData) {
      return limitId == 'ai_chat_trial'
        && isValidTrialAIUsage(data)
        && data.metric == existingData.metric
        && data.scope == existingData.scope
        && data.limit == existingData.limit
        && data.count == existingData.count + 1;
    }

    // Per-plan monthly Fluxy AI counter (`ai_chat_<YYYY-MM>`). The limit is
    // re-derived from the user's ACTIVE subscription plan via get(), so a client
    // cannot inflate it. Mirrors PLAN_AI_MONTHLY_LIMITS in netlify/functions/api.js
    // and ai_chat_limit in assets/js/billing-config.js. Enterprise (unlimited)
    // writes no counter, so it has no entry here.
    function planMonthlyAiLimit(planId) {
      return planId == 'starter' ? 25
        : (planId == 'core' || planId == 'basic') ? 150
        : planId == 'growth' ? 750
        : -1;
    }

    function activePlanAiLimit(userId) {
      let path = /databases/$(database)/documents/users/$(userId)/billing_subscription/current;
      let sub = exists(path) ? get(path).data : null;
      return (sub != null && (sub.status == 'active' || sub.status == 'cancel_scheduled'))
        ? planMonthlyAiLimit(sub.plan_id)
        : -1;
    }

    function isValidPlanAIUsageShape(userId, data) {
      let limit = activePlanAiLimit(userId);
      return data.keys().hasAll(['metric', 'scope', 'period', 'count', 'limit'])
        && data.keys().hasOnly(['metric', 'scope', 'period', 'count', 'limit'])
        && data.metric == 'ai_chat_requests'
        && data.scope == 'plan'
        && data.period is string
        && limit > 0
        && data.limit == limit
        && data.count is number
        && data.count >= 1
        && data.count <= limit;
    }

    function isValidPlanAIUsageCreate(limitId, userId, data) {
      return limitId.matches('ai_chat_[0-9]{4}-[0-9]{2}')
        && isValidPlanAIUsageShape(userId, data)
        && data.count == 1;
    }

    function isValidPlanAIUsageUpdate(limitId, userId, data, existingData) {
      return limitId.matches('ai_chat_[0-9]{4}-[0-9]{2}')
        && isValidPlanAIUsageShape(userId, data)
        && data.metric == existingData.metric
        && data.scope == existingData.scope
        && data.period == existingData.period
        && data.limit == existingData.limit
        && data.count == existingData.count + 1;
    }

    function isValidSettingsTimestamp(data) {
      return data.updated_at == request.time;
    }

    function isValidCompanySettings(data) {
      return data.keys().hasAll([
          'business_name',
          'business_type',
          'country',
          'entity_label',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'business_name',
          'business_type',
          'country',
          'entity_label',
          'updated_at'
        ])
        && data.business_name is string
        && data.business_name.size() > 0
        && data.business_name.size() <= 120
        && data.business_type is string
        && data.business_type.size() <= 80
        && data.country is string
        && data.country.size() > 0
        && data.country.size() <= 80
        && data.entity_label is string
        && data.entity_label.size() > 0
        && data.entity_label.size() <= 80
        && isValidSettingsTimestamp(data);
    }

    function isValidFinanceSettings(data) {
      return data.keys().hasAll([
          'currency',
          'locale',
          'timezone',
          'date_format',
          'categories',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'currency',
          'locale',
          'timezone',
          'date_format',
          'categories',
          'updated_at'
        ])
        && data.currency == 'IDR'
        && data.locale == 'id-ID'
        && data.timezone in ['Asia/Jakarta', 'Asia/Makassar', 'Asia/Jayapura']
        && data.date_format in ['DD MMM YYYY', 'DD/MM/YYYY', 'YYYY-MM-DD']
        && data.categories is list
        && data.categories.size() <= 8
        && isValidSettingsTimestamp(data);
    }

    function isValidImportRulesSettings(data) {
      return data.keys().hasAll([
          'csv_date_behavior',
          'unknown_document_route',
          'bill_scan_behavior',
          'receipt_scan_behavior',
          'payment_screenshot_behavior',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'csv_date_behavior',
          'unknown_document_route',
          'bill_scan_behavior',
          'receipt_scan_behavior',
          'payment_screenshot_behavior',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.csv_date_behavior in ['use_row_date', 'use_upload_date']
        && data.unknown_document_route == 'ai_review'
        && data.bill_scan_behavior == 'create_bill_draft'
        && data.receipt_scan_behavior == 'create_ledger_draft'
        && data.payment_screenshot_behavior == 'create_review_item'
        && data.require_confirmation_before_save == true
        && isValidSettingsTimestamp(data);
    }

    function isValidAISettings(data) {
      return data.keys().hasAll([
          'answer_style',
          'default_analysis_period',
          'show_data_quality_warnings',
          'allow_ai_suggestions',
          'allow_ai_draft_actions',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'answer_style',
          'default_analysis_period',
          'show_data_quality_warnings',
          'allow_ai_suggestions',
          'allow_ai_draft_actions',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.answer_style in ['concise', 'practical', 'detailed']
        && data.default_analysis_period in ['current_month', 'last_month', 'last_90_days']
        && data.show_data_quality_warnings is bool
        && data.allow_ai_suggestions is bool
        && data.allow_ai_draft_actions is bool
        && data.require_confirmation_before_save == true
        && isValidSettingsTimestamp(data);
    }

    function isValidReportsSettings(data) {
      return data.keys().hasOnly([
          'arr_source',
          'recurring_revenue_category_ids',
          'updated_at'
        ])
        && data.arr_source in ['none', 'tagged_income_categories']
        && data.recurring_revenue_category_ids is list
        && data.recurring_revenue_category_ids.size() <= 32
        && isValidSettingsTimestamp(data);
    }

    function isValidWhatsAppSettings(data) {
      return data.keys().hasAll([
          'status',
          'phone_number',
          'business_display_name',
          'last_sync_at',
          'last_verified_at',
          'provider',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'status',
          'phone_number',
          'business_display_name',
          'last_sync_at',
          'last_verified_at',
          'provider',
          'updated_at'
        ])
        && data.status in ['not_connected', 'pending', 'connected']
        && (data.phone_number == null || (data.phone_number is string && data.phone_number.size() <= 32))
        && (data.business_display_name == null || (data.business_display_name is string && data.business_display_name.size() <= 120))
        && (data.last_sync_at == null || data.last_sync_at is timestamp)
        && (data.last_verified_at == null || data.last_verified_at is timestamp)
        && data.provider == 'whatsapp_cloud_api'
        && isValidSettingsTimestamp(data);
    }

    function isValidSettingsDoc(settingsDoc, data) {
      return (settingsDoc == 'company' && isValidCompanySettings(data))
        || (settingsDoc == 'finance' && isValidFinanceSettings(data))
        || (settingsDoc == 'import_rules' && isValidImportRulesSettings(data))
        || (settingsDoc == 'ai' && isValidAISettings(data))
        || (settingsDoc == 'whatsapp' && isValidWhatsAppSettings(data))
        || (settingsDoc == 'reports' && isValidReportsSettings(data))
        || (settingsDoc == 'email_preferences' && isValidEmailPreferencesSettings(data));
    }

    // Weekly Financial Digest preferences (users/{uid}/settings/email_preferences).
    // Enums/bools/bounds only — no secrets. See docs/PROJECT_BACKGROUND.md §4e.
    function isValidEmailPreferencesSettings(data) {
      return data.keys().hasOnly([
          'weekly_digest_enabled', 'delivery_day', 'delivery_hour', 'timezone', 'metrics', 'updated_at'
        ])
        && data.keys().hasAll([
          'weekly_digest_enabled', 'delivery_day', 'delivery_hour', 'timezone', 'metrics', 'updated_at'
        ])
        && data.weekly_digest_enabled is bool
        && data.delivery_day in ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday']
        && data.delivery_hour is int && data.delivery_hour >= 0 && data.delivery_hour <= 23
        && data.timezone is string && data.timezone.size() > 0 && data.timezone.size() <= 64
        && data.metrics is map
        && data.metrics.keys().hasOnly([
          'financial_health', 'cash_position', 'bills', 'budgets', 'revenue', 'expenses', 'subscriptions', 'vendors'
        ])
        && data.metrics.keys().hasAll([
          'financial_health', 'cash_position', 'bills', 'budgets', 'revenue', 'expenses', 'subscriptions', 'vendors'
        ])
        && data.metrics.financial_health is bool
        && data.metrics.cash_position is bool
        && data.metrics.bills is bool
        && data.metrics.budgets is bool
        && data.metrics.revenue is bool
        && data.metrics.expenses is bool
        && data.metrics.subscriptions is bool
        && data.metrics.vendors is bool
        && isValidSettingsTimestamp(data);
    }

    function isValidTourId(tourId) {
      return tourId == null
        || tourId in ['overview', 'ledger', 'bills', 'fluxy_ai', 'revenue_sync', 'subscriptions'];
    }

    function isValidPlatformLearningState(data) {
      return data.keys().hasOnly([
          'dismissed',
          'dismissed_at',
          'first_rendered_at',
          'last_seen_at',
          'started_tours',
          'completed_tours',
          'skipped_tours',
          'active_tour',
          'updated_at'
        ])
        && (!('dismissed' in data) || data.dismissed is bool)
        && (!('dismissed_at' in data) || data.dismissed_at == null || data.dismissed_at is timestamp)
        && (!('first_rendered_at' in data) || data.first_rendered_at is timestamp)
        && (!('last_seen_at' in data) || data.last_seen_at is timestamp)
        && (!('started_tours' in data) || (data.started_tours is list && data.started_tours.size() <= 12))
        && (!('completed_tours' in data) || (data.completed_tours is list && data.completed_tours.size() <= 12))
        && (!('skipped_tours' in data) || (data.skipped_tours is list && data.skipped_tours.size() <= 12))
        && (!('active_tour' in data) || isValidTourId(data.active_tour))
        && (!('updated_at' in data) || data.updated_at == request.time);
    }

    function isValidBankAccount(data) {
      return data.keys().hasAll([
          'account_name',
          'bank_name',
          'currency',
          'source_type',
          'status',
          'latest_balance',
          'latest_balance_at',
          'sync_status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'account_name',
          'bank_name',
          'bank_code',
          'currency',
          'last_four',
          'source_type',
          'provider',
          'provider_account_id',
          'status',
          'latest_balance',
          'latest_balance_at',
          'sync_status',
          'last_sync_at',
          'confidence',
          'notes',
          'created_at',
          'updated_at'
        ])
        && data.account_name is string
        && data.account_name.size() > 0
        && data.account_name.size() <= 120
        && data.bank_name is string
        && data.bank_name.size() > 0
        && data.bank_name.size() <= 80
        && (!('bank_code' in data) || data.bank_code == null || (data.bank_code is string && data.bank_code.size() <= 16))
        && data.currency == 'IDR'
        && (!('last_four' in data) || data.last_four == null || (data.last_four is string && data.last_four.size() <= 4))
        && data.source_type in ['manual', 'statement_upload', 'auto_sync']
        && (!('provider' in data) || data.provider == null || (data.provider is string && data.provider.size() <= 40))
        && (!('provider_account_id' in data) || data.provider_account_id == null || (data.provider_account_id is string && data.provider_account_id.size() <= 120))
        && data.status in ['active', 'archived']
        && data.latest_balance is number
        && data.latest_balance >= 0
        && data.latest_balance <= 999999999999
        && data.latest_balance_at is timestamp
        && data.sync_status in ['manual', 'pending', 'connected', 'failed']
        && (!('last_sync_at' in data) || data.last_sync_at == null || data.last_sync_at is timestamp)
        && (!('confidence' in data) || data.confidence == null || data.confidence in ['user_entered', 'extracted', 'synced'])
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500));
    }

    function isValidBankAccountCreate(data) {
      return isValidBankAccount(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidBankAccountUpdate(data, existingData) {
      return isValidBankAccount(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    function isValidBankBalanceSnapshot(data) {
      return data.keys().hasAll([
          'bank_account_id',
          'balance',
          'currency',
          'source_type',
          'snapshot_at',
          'created_at'
        ])
        && data.keys().hasOnly([
          'bank_account_id',
          'balance',
          'currency',
          'source_type',
          'snapshot_at',
          'confidence',
          'notes',
          'created_at'
        ])
        && data.bank_account_id is string
        && data.bank_account_id.size() > 0
        && data.bank_account_id.size() <= 120
        && data.balance is number
        && data.balance >= 0
        && data.balance <= 999999999999
        && data.currency == 'IDR'
        && data.source_type in ['manual', 'statement_upload', 'auto_sync']
        && data.snapshot_at is timestamp
        && (!('confidence' in data) || data.confidence == null || data.confidence in ['user_entered', 'extracted', 'synced'])
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500))
        && data.created_at == request.time;
    }

    function isValidBudget(data) {
      return data.keys().hasAll([
          'name',
          'period_type',
          'period_start',
          'period_end',
          'currency',
          'total_budget',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'name',
          'budget_type',
          'parent_budget_id',
          'period_type',
          'period_label',
          'period_start',
          'period_end',
          'currency',
          'total_budget',
          'category_budgets',
          'notes',
          'status',
          'created_from_budget_id',
          'created_at',
          'updated_at'
        ])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && (!('budget_type' in data) || data.budget_type in ['annual', 'period'])
        && (!('parent_budget_id' in data) || data.parent_budget_id == null || (data.parent_budget_id is string && data.parent_budget_id.size() <= 120))
        && data.period_type in ['monthly', 'quarterly', 'yearly', 'custom']
        && (!('period_label' in data) || data.period_label == null || (data.period_label is string && data.period_label.size() <= 120))
        && data.period_start is timestamp
        && data.period_end is timestamp
        && data.currency == 'IDR'
        && data.total_budget is number
        && data.total_budget >= 0
        && data.total_budget <= 999999999999
        && (!('category_budgets' in data) || data.category_budgets is map)
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500))
        && (!('created_from_budget_id' in data) || data.created_from_budget_id == null || (data.created_from_budget_id is string && data.created_from_budget_id.size() <= 120))
        && data.status in ['active', 'archived'];
    }

    function isValidBudgetAllocation(data) {
      return data.keys().hasAll([
          'parent_budget_id',
          'name',
          'allocated_amount',
          'scope_type',
          'scope_values',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'parent_budget_id',
          'name',
          'allocated_amount',
          'scope_type',
          'scope_values',
          'alert_threshold_percent',
          'hard_limit_enabled',
          'created_from_allocation_id',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.parent_budget_id is string
        && data.parent_budget_id.size() > 0
        && data.parent_budget_id.size() <= 120
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.allocated_amount is number
        && data.allocated_amount >= 0
        && data.allocated_amount <= 999999999999
        && data.scope_type == 'category'
        && data.scope_values is list
        && data.scope_values.size() > 0
        && data.scope_values.size() <= 10
        && (!('alert_threshold_percent' in data) || data.alert_threshold_percent == null || (data.alert_threshold_percent is number && data.alert_threshold_percent >= 0 && data.alert_threshold_percent <= 100))
        && (!('hard_limit_enabled' in data) || data.hard_limit_enabled is bool)
        && (!('created_from_allocation_id' in data) || data.created_from_allocation_id == null || (data.created_from_allocation_id is string && data.created_from_allocation_id.size() <= 120))
        && data.status in ['active', 'archived'];
    }

    function isValidBudgetAllocationCreate(data) {
      return isValidBudgetAllocation(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidBudgetAllocationUpdate(data, existingData) {
      return isValidBudgetAllocation(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    function isValidBillBudgetFields(data) {
      return (!('budget_id' in data) || data.budget_id == null || (data.budget_id is string && data.budget_id.size() <= 120))
        && (!('budget_allocation_id' in data) || data.budget_allocation_id == null || (data.budget_allocation_id is string && data.budget_allocation_id.size() <= 120))
        && (!('budget_match_method' in data) || data.budget_match_method == null || data.budget_match_method in ['auto', 'manual', 'rule', 'excluded', 'none'])
        && (!('budget_match_status' in data) || data.budget_match_status == null || data.budget_match_status in ['matched', 'needs_review', 'unmatched', 'excluded'])
        && (!('budget_impact_status' in data) || data.budget_impact_status == null || data.budget_impact_status in ['committed', 'released', 'converted_to_actual'])
        && (!('budget_assignment_reason' in data) || data.budget_assignment_reason == null || (data.budget_assignment_reason is string && data.budget_assignment_reason.size() <= 500))
        && (!('budget_assignment_updated_at' in data) || data.budget_assignment_updated_at == null || data.budget_assignment_updated_at is timestamp)
        && (!('budget_assignment_updated_by' in data) || data.budget_assignment_updated_by == null || (data.budget_assignment_updated_by is string && data.budget_assignment_updated_by == request.auth.uid))
        && (!('budget_exclusion_reason' in data) || data.budget_exclusion_reason == null || (data.budget_exclusion_reason is string && data.budget_exclusion_reason.size() <= 500));
    }

    function isValidTransactionBudgetFields(data) {
      return (!('budget_id' in data) || data.budget_id == null || (data.budget_id is string && data.budget_id.size() <= 120))
        && (!('budget_allocation_id' in data) || data.budget_allocation_id == null || (data.budget_allocation_id is string && data.budget_allocation_id.size() <= 120))
        && (!('budget_match_method' in data) || data.budget_match_method == null || data.budget_match_method in ['auto', 'manual', 'rule', 'excluded', 'none'])
        && (!('budget_match_status' in data) || data.budget_match_status == null || data.budget_match_status in ['matched', 'needs_review', 'unmatched', 'excluded'])
        && (!('budget_match_confidence' in data) || data.budget_match_confidence == null || (data.budget_match_confidence is number && data.budget_match_confidence >= 0 && data.budget_match_confidence <= 1))
        && (!('budget_assignment_reason' in data) || data.budget_assignment_reason == null || (data.budget_assignment_reason is string && data.budget_assignment_reason.size() <= 500))
        && (!('budget_assignment_updated_at' in data) || data.budget_assignment_updated_at == null || data.budget_assignment_updated_at is timestamp)
        && (!('budget_assignment_updated_by' in data) || data.budget_assignment_updated_by == null || (data.budget_assignment_updated_by is string && data.budget_assignment_updated_by == request.auth.uid))
        && (!('budget_exclusion_reason' in data) || data.budget_exclusion_reason == null || (data.budget_exclusion_reason is string && data.budget_exclusion_reason.size() <= 500));
    }

    function preservesLegacyRecordDate(data, existingData) {
      return !('date' in data)
        || (('date' in existingData) && data.date == existingData.date);
    }

    function isValidBudgetCreate(data) {
      return isValidBudget(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidBudgetUpdate(data, existingData) {
      return isValidBudget(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    // ===== Invoices (Create Invoice MVP) =====
    // Customer invoices under users/{uid}/invoices. Amounts are raw integer
    // Rupiah — never formatted strings. A finalized (open) invoice is an
    // expected receivable only; it never creates a ledger transaction.
    // See docs/fluxyos_create_invoice_feature_plan.md.
    function isValidInvoiceAmounts(data) {
      return data.subtotal_amount is number
        && data.subtotal_amount >= 0
        && data.subtotal_amount <= 999999999999
        && data.tax_amount is number
        && data.tax_amount >= 0
        && data.tax_amount <= 999999999999
        && data.discount_amount is number
        && data.discount_amount >= 0
        && data.discount_amount <= 999999999999
        && data.total_amount is number
        && data.total_amount >= 0
        && data.total_amount <= 999999999999
        && data.amount_due is number
        && data.amount_due >= 0
        && data.amount_due <= 999999999999;
    }

    function isValidInvoiceBase(data) {
      return data.keys().hasOnly([
          'invoice_number',
          'status',
          'currency',
          'customer_name',
          'customer_email',
          'customer_language',
          'issue_date',
          'due_date',
          'due_terms',
          'item_count',
          'subtotal_amount',
          'tax_amount',
          'tax_rate_percent',
          'discount_amount',
          'total_amount',
          'amount_due',
          'memo',
          'footer',
          'payment_collection_method',
          'payment_link_enabled',
          'payment_page_url',
          'finalized_at',
          'sent_at',
          'paid_at',
          'linked_transaction_id',
          'voided_at',
          'void_reason',
          'created_at',
          'updated_at',
          'created_by',
          'updated_by'
        ])
        && data.keys().hasAll([
          'invoice_number',
          'status',
          'currency',
          'customer_name',
          'customer_email',
          'issue_date',
          'due_terms',
          'item_count',
          'subtotal_amount',
          'tax_amount',
          'discount_amount',
          'total_amount',
          'amount_due',
          'payment_collection_method',
          'created_at',
          'updated_at',
          'created_by',
          'updated_by'
        ])
        && data.invoice_number is string
        && data.invoice_number.size() > 0
        && data.invoice_number.size() <= 40
        && data.status in ['draft', 'open', 'void', 'paid']
        && data.currency == 'IDR'
        && data.customer_name is string
        && data.customer_name.size() <= 160
        && (data.customer_email == null
          || (data.customer_email is string && data.customer_email.size() <= 160))
        && (!('customer_language' in data)
          || (data.customer_language is string && data.customer_language.size() <= 40))
        && data.issue_date is timestamp
        && (!('due_date' in data) || data.due_date == null || data.due_date is timestamp)
        && data.due_terms is string
        && data.due_terms.size() <= 40
        && data.item_count is number
        && data.item_count >= 0
        && data.item_count <= 200
        && isValidInvoiceAmounts(data)
        && (!('tax_rate_percent' in data)
          || data.tax_rate_percent == null
          || (data.tax_rate_percent is number && data.tax_rate_percent >= 0 && data.tax_rate_percent <= 100))
        && (!('memo' in data)
          || data.memo == null
          || (data.memo is string && data.memo.size() <= 500))
        && (!('footer' in data)
          || data.footer == null
          || (data.footer is string && data.footer.size() <= 500))
        && data.payment_collection_method in ['request_payment', 'manual_only']
        && (!('payment_link_enabled' in data) || data.payment_link_enabled is bool)
        && (!('payment_page_url' in data) || data.payment_page_url == null)
        && (!('finalized_at' in data) || data.finalized_at == null || data.finalized_at is timestamp)
        && (!('sent_at' in data) || data.sent_at == null || data.sent_at is timestamp)
        && (!('paid_at' in data) || data.paid_at == null || data.paid_at is timestamp)
        && (!('linked_transaction_id' in data)
          || data.linked_transaction_id == null
          || (data.linked_transaction_id is string && data.linked_transaction_id.size() <= 160))
        && (!('voided_at' in data) || data.voided_at == null || data.voided_at is timestamp)
        && (!('void_reason' in data)
          || data.void_reason == null
          || (data.void_reason is string && data.void_reason.size() > 0 && data.void_reason.size() <= 500));
    }

    function isValidInvoiceCreate(data) {
      return isValidInvoiceBase(data)
        && data.status == 'draft'
        && (!('finalized_at' in data) || data.finalized_at == null)
        && (!('sent_at' in data) || data.sent_at == null)
        && (!('paid_at' in data) || data.paid_at == null)
        && (!('linked_transaction_id' in data) || data.linked_transaction_id == null)
        && (!('voided_at' in data) || data.voided_at == null)
        && (!('void_reason' in data) || data.void_reason == null)
        && data.created_at == request.time
        && data.updated_at == request.time
        && data.created_by == request.auth.uid
        && data.updated_by == request.auth.uid;
    }

    function isValidInvoiceUpdate(data, existingData) {
      return isValidInvoiceBase(data)
        && data.created_at == existingData.created_at
        && data.created_by == existingData.created_by
        && data.invoice_number == existingData.invoice_number
        && data.updated_at == request.time
        && data.updated_by == request.auth.uid
        && existingData.status in ['draft', 'open']
        && (
          // Draft edits stay draft.
          (existingData.status == 'draft'
            && data.status == 'draft'
            && (!('finalized_at' in data) || data.finalized_at == null)
            && (!('paid_at' in data) || data.paid_at == null)
            && (!('linked_transaction_id' in data) || data.linked_transaction_id == null)
            && (!('voided_at' in data) || data.voided_at == null))
          // Finalize: draft -> open. Requires customer, due date, items, total.
          || (existingData.status == 'draft'
            && data.status == 'open'
            && data.finalized_at == request.time
            && data.customer_name.size() > 0
            && data.total_amount > 0
            && data.item_count > 0
            && data.due_date is timestamp
            && (!('sent_at' in data) || data.sent_at == null || data.sent_at == request.time)
            && (!('paid_at' in data) || data.paid_at == null)
            && (!('linked_transaction_id' in data) || data.linked_transaction_id == null)
            && (!('voided_at' in data) || data.voided_at == null))
          // Finalize-only edits: an open invoice that has NOT been sent stays
          // editable in full. It remains open + unsent and keeps finalized_at;
          // the same required-field checks as finalize apply.
          || (existingData.status == 'open'
            && (!('sent_at' in existingData) || existingData.sent_at == null)
            && data.status == 'open'
            && data.finalized_at == existingData.finalized_at
            && (!('sent_at' in data) || data.sent_at == null)
            && (!('paid_at' in data) || data.paid_at == null)
            && (!('linked_transaction_id' in data) || data.linked_transaction_id == null)
            && (!('voided_at' in data) || data.voided_at == null)
            && data.customer_name.size() > 0
            && data.total_amount > 0
            && data.item_count > 0
            && data.due_date is timestamp)
          // Open invoices: metadata-only edits (memo/footer/record sent).
          || (existingData.status == 'open'
            && data.status == 'open'
            && data.diff(existingData).affectedKeys().hasOnly(['memo', 'footer', 'sent_at', 'updated_at', 'updated_by']))
          // Mark paid: open -> paid. Stamps paid_at and links the income
          // ledger transaction created in the same batch. Terminal: no edit,
          // void, or un-pay path exists after this.
          || (existingData.status == 'open'
            && data.status == 'paid'
            && data.paid_at == request.time
            && data.linked_transaction_id is string
            && data.linked_transaction_id.size() > 0
            && data.diff(existingData).affectedKeys().hasOnly(
                 ['status', 'paid_at', 'linked_transaction_id', 'updated_at', 'updated_by']))
          // Void instead of delete: draft/open -> void with a required reason.
          || (data.status == 'void'
            && data.voided_at == request.time
            && data.void_reason is string
            && data.void_reason.size() > 0
            && data.void_reason.size() <= 500)
        );
    }

    function isValidInvoiceItem(data) {
      return data.keys().hasOnly([
          'description',
          'quantity',
          'unit_price',
          'amount',
          'position',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasAll([
          'description',
          'quantity',
          'unit_price',
          'amount',
          'created_at',
          'updated_at'
        ])
        && data.description is string
        && data.description.size() > 0
        && data.description.size() <= 240
        && data.quantity is number
        && data.quantity > 0
        && data.quantity <= 999999
        && data.unit_price is number
        && data.unit_price >= 0
        && data.unit_price <= 999999999999
        && data.amount is number
        && data.amount >= 0
        && data.amount <= 999999999999
        && (!('position' in data) || (data.position is number && data.position >= 0 && data.position <= 200));
    }

    // Items can only be written while the parent invoice is (or becomes, in
    // the same batch) editable: a draft, or a finalized-but-unsent ("finalize
    // only") open invoice. getAfter sees post-commit state so the create-draft
    // batch (invoice + items together) validates correctly.
    function invoiceIsDraftAfterWrite(userId, invoiceId) {
      let inv = getAfter(/databases/$(database)/documents/users/$(userId)/invoices/$(invoiceId)).data;
      return inv.status == 'draft'
        || (inv.status == 'open' && (!('sent_at' in inv) || inv.sent_at == null));
    }

    function isValidBankStatementImport(data) {
      return data.keys().hasAll([
          'file_name',
          'file_mime_type',
          'file_size',
          'document_type',
          'extraction_status',
          'review_status',
          'currency',
          'row_count',
          'balance_check_status',
          'running_balance_check_status',
          'duplicate_count',
          'needs_review_count',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'bank_account_id',
          'file_name',
          'file_mime_type',
          'file_size',
          'storage_path',
          'document_type',
          'extraction_status',
          'review_status',
          'bank_name',
          'account_holder',
          'account_number_masked',
          'currency',
          'statement_start_date',
          'statement_end_date',
          'opening_balance',
          'closing_balance',
          'total_debit',
          'total_credit',
          'row_count',
          'balance_check_status',
          'running_balance_check_status',
          'duplicate_count',
          'needs_review_count',
          'created_at',
          'updated_at',
          'confirmed_at',
          'imported_at'
        ])
        && data.file_name is string
        && data.file_name.size() > 0
        && data.file_name.size() <= 240
        && data.file_mime_type is string
        && data.file_mime_type.size() <= 160
        && data.file_size is number
        && data.file_size >= 0
        && data.file_size <= 10 * 1024 * 1024
        && (!('storage_path' in data) || data.storage_path == null || (data.storage_path is string && data.storage_path.size() <= 400))
        && data.document_type == 'bank_statement'
        && data.extraction_status in ['pending', 'processing', 'completed', 'failed']
        && data.review_status in ['draft', 'needs_review', 'ready_to_import', 'imported', 'rejected']
        && (!('bank_account_id' in data) || data.bank_account_id == null || (data.bank_account_id is string && data.bank_account_id.size() <= 120))
        && (!('bank_name' in data) || data.bank_name == null || (data.bank_name is string && data.bank_name.size() <= 80))
        && (!('account_holder' in data) || data.account_holder == null || (data.account_holder is string && data.account_holder.size() <= 160))
        && (!('account_number_masked' in data) || data.account_number_masked == null || (data.account_number_masked is string && data.account_number_masked.size() <= 32))
        && data.currency == 'IDR'
        && (!('statement_start_date' in data) || data.statement_start_date == null || data.statement_start_date is timestamp)
        && (!('statement_end_date' in data) || data.statement_end_date == null || data.statement_end_date is timestamp)
        && (!('opening_balance' in data) || data.opening_balance == null || data.opening_balance is number)
        && (!('closing_balance' in data) || data.closing_balance == null || data.closing_balance is number)
        && (!('total_debit' in data) || data.total_debit == null || data.total_debit is number)
        && (!('total_credit' in data) || data.total_credit == null || data.total_credit is number)
        && data.row_count is number
        && data.row_count >= 0
        && data.balance_check_status in ['passed', 'failed', 'unavailable']
        && data.running_balance_check_status in ['passed', 'failed', 'unavailable']
        && data.duplicate_count is number
        && data.duplicate_count >= 0
        && data.needs_review_count is number
        && data.needs_review_count >= 0
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && (!('confirmed_at' in data) || data.confirmed_at == null || data.confirmed_at is timestamp)
        && (!('imported_at' in data) || data.imported_at == null || data.imported_at is timestamp);
    }

    function isValidBankStatementImportCreate(userId, data) {
      return isValidBankStatementImport(data)
        && data.created_at == request.time
        && data.updated_at == request.time
        && respectsTrialStorageSingleFileLimit(userId, data)
        && data.review_status == 'draft'
        && data.extraction_status == 'pending'
        && (!('storage_path' in data) || data.storage_path == null
              || data.storage_path.matches('users/' + userId + '/bank_statement_imports/.*'));
    }

    function isValidBankStatementImportUpdate(userId, data, existingData) {
      return isValidBankStatementImport(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time
        && data.file_name == existingData.file_name
        && data.file_mime_type == existingData.file_mime_type
        && data.file_size == existingData.file_size
        && (!('storage_path' in data) || data.storage_path == null
              || data.storage_path.matches('users/' + userId + '/bank_statement_imports/.*'));
    }

    function isValidBankStatementRow(data) {
      return data.keys().hasOnly([
          'row_index',
          'transaction_date',
          'posting_date',
          'description_raw',
          'debit',
          'credit',
          'running_balance',
          'suggested_vendor_name',
          'suggested_category',
          'suggested_type',
          'match_status',
          'matched_transaction_id',
          'confidence',
          'selected_for_import',
          'review_status',
          'created_transaction_id',
          'created_at'
        ])
        && data.row_index is number
        && data.row_index >= 0
        && (!('transaction_date' in data) || data.transaction_date == null || data.transaction_date is timestamp)
        && (!('posting_date' in data) || data.posting_date == null || data.posting_date is timestamp)
        && (!('description_raw' in data) || data.description_raw == null || (data.description_raw is string && data.description_raw.size() <= 500))
        && (!('debit' in data) || data.debit == null || data.debit is number)
        && (!('credit' in data) || data.credit == null || data.credit is number)
        && (!('running_balance' in data) || data.running_balance == null || data.running_balance is number)
        && (!('suggested_vendor_name' in data) || data.suggested_vendor_name == null || (data.suggested_vendor_name is string && data.suggested_vendor_name.size() <= 160))
        && (!('suggested_category' in data) || data.suggested_category == null || (data.suggested_category is string && data.suggested_category.size() <= 80))
        && (!('suggested_type' in data) || data.suggested_type == null || (data.suggested_type is string && data.suggested_type.size() <= 40))
        && (!('match_status' in data) || data.match_status in ['new', 'possible_duplicate', 'matched_existing', 'ignored', 'needs_review'])
        && (!('matched_transaction_id' in data) || data.matched_transaction_id == null || (data.matched_transaction_id is string && data.matched_transaction_id.size() <= 120))
        && (!('confidence' in data) || data.confidence == null || data.confidence is number)
        && (!('selected_for_import' in data) || data.selected_for_import is bool)
        && (!('review_status' in data) || data.review_status in ['pending', 'confirmed', 'ignored'])
        && (!('created_transaction_id' in data) || data.created_transaction_id == null || (data.created_transaction_id is string && data.created_transaction_id.size() <= 120))
        && data.created_at is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      // 3-day trial / billing access state (owner-scoped). Client writes are UX
      // only; production enforcement still needs backend/Cloud Functions.
      match /billing/{billingDoc} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      // Manual payment proof submissions (owner-scoped). Proof file lives in the
      // documents collection / Storage; this doc holds metadata + status only.
      match /payment_verifications/{paymentId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      match /billing_payment_requests/{paymentRequestId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBillingPaymentRequest(request.resource.data)
          && hasValidPaymentRequestPrevSnapshot(userId, request.resource.data)
          && hasValidPaymentRequestVoucher(userId, paymentRequestId, request.resource.data);
        // Owner may confirm a QRIS payment (awaiting_payment -> pending_verification)
        // or cancel an in-flight payment (-> canceled).
        allow update: if isOwner(userId)
          && (
            isValidPaymentRequestVerificationSubmit(resource.data, request.resource.data)
            || isValidPaymentRequestCancel(resource.data, request.resource.data)
          );
        allow delete: if false;
      }

      match /billing_subscription/{subscriptionId} {
        allow read: if isOwner(userId) && subscriptionId == 'current';
        allow create: if isOwner(userId)
          && subscriptionId == 'current'
          && isValidBillingSubscription(request.resource.data)
          && (isTrialSubscriptionCreate(request.resource.data)
            || isCheckoutSubscriptionWrite(userId, request.resource.data)
            || isCheckoutAwaitingPaymentWrite(userId, request.resource.data)
            || isLegacyBillingMigration(userId, request.resource.data));
        allow update: if isOwner(userId)
          && subscriptionId == 'current'
          && isValidBillingSubscription(request.resource.data)
          && (
            isCheckoutSubscriptionWrite(userId, request.resource.data)
            || isCheckoutAwaitingPaymentWrite(userId, request.resource.data)
            || isCancelPaymentRevert(userId, resource.data, request.resource.data)
            || isCancelRestoreActive(userId, resource.data, request.resource.data)
            || isCancelRenewalWrite(resource.data, request.resource.data)
            || isReactivateRenewalWrite(resource.data, request.resource.data)
            || isInternalReviewReconcile(userId, resource.data, request.resource.data)
            || isActiveBillingPeriodBackfill(userId, resource.data, request.resource.data)
            || isLegacyBillingMigration(userId, request.resource.data)
            || (resource.data.status == 'trialing'
              && request.resource.data.status == 'expired'
              && resource.data.trial_ends_at is timestamp
              && resource.data.trial_ends_at < request.time
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']))
          );
        allow delete: if false;
      }

      // Provider/backend-owned invoice history surfaced read-only on the
      // Billing & plan settings page (users/{uid}/billing_invoices). Invoices
      // are issued by a trusted backend after a successful payment, never by the
      // client, so every client write is blocked.
      match /billing_invoices/{invoiceId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'created_at',
            'receipt_url',
            'attached_documents',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'payment_reference',
            'notes',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_match_confidence',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason',
            'cash_effective',
            'cash_status',
            'cash_direction',
            'cash_account_id',
            'cash_source',
            'cash_match_status',
            'cash_effective_at',
            'bank_statement_import_id',
            'bank_statement_row_id',
            'imported_at',
            'bank_account_id',
            'linked_bill_id'
          ])
          && isValidBaseRecord(request.resource.data)
          && (!('created_at' in request.resource.data) || request.resource.data.created_at == request.time)
          && (!('receipt_url' in request.resource.data) || request.resource.data.receipt_url is string)
          && (!('linked_bill_id' in request.resource.data) || request.resource.data.linked_bill_id == null || (request.resource.data.linked_bill_id is string && request.resource.data.linked_bill_id.size() <= 120))
          && isValidTransactionBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'date',
            'timestamp',
            'created_at',
            'receipt_url',
            'attached_documents',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'payment_reference',
            'notes',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_match_confidence',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason',
            'cash_effective',
            'cash_status',
            'cash_direction',
            'cash_account_id',
            'cash_source',
            'cash_match_status',
            'cash_effective_at',
            'cash_assignment_reason',
            'cash_assignment_updated_at',
            'cash_assignment_updated_by',
            'updated_at',
            'updated_by',
            'is_voided',
            'voided_at',
            'voided_by',
            'void_reason',
            'bank_statement_import_id',
            'bank_statement_row_id',
            'imported_at',
            'bank_account_id',
            'linked_bill_id'
          ])
          && isValidTransactionRecordUpdate(request.resource.data, resource.data)
          && preservesLegacyRecordDate(request.resource.data, resource.data)
          && (!('linked_bill_id' in request.resource.data) || request.resource.data.linked_bill_id == null || (request.resource.data.linked_bill_id is string && request.resource.data.linked_bill_id.size() <= 120))
          && isValidTransactionBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow delete: if false;
      }

      match /bills/{billId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'due_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'payment_status',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'attached_documents',
            'invoice_status',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_impact_status',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason'
          ])
          && isValidBaseRecord(request.resource.data)
          && (!('due_date' in request.resource.data) || request.resource.data.due_date is timestamp)
          && (!('payment_status' in request.resource.data) || request.resource.data.payment_status in ['unpaid', 'paid', 'overdue', 'unknown'])
          && (!('invoice_status' in request.resource.data) || request.resource.data.invoice_status in ['attached'])
          && isValidBillBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'date',
            'due_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'payment_status',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'attached_documents',
            'invoice_status',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_impact_status',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason',
            'linked_transaction_id',
            'updated_at',
            'updated_by'
          ])
          && isValidBaseRecordUpdate(request.resource.data, resource.data)
          && preservesLegacyRecordDate(request.resource.data, resource.data)
          && (!('due_date' in request.resource.data) || request.resource.data.due_date is timestamp)
          && (!('payment_status' in request.resource.data) || request.resource.data.payment_status in ['unpaid', 'paid', 'overdue', 'unknown'])
          && (!('invoice_status' in request.resource.data) || request.resource.data.invoice_status in ['attached'])
          && (!('linked_transaction_id' in request.resource.data) || request.resource.data.linked_transaction_id == null || (request.resource.data.linked_transaction_id is string && request.resource.data.linked_transaction_id.size() <= 120))
          && isValidBillBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow delete: if false;
      }

      match /subscriptions/{subscriptionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'renewal_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'billing_cycle',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'notes',
            'attached_documents'
          ])
          && isValidBaseRecord(request.resource.data)
          && (!('renewal_date' in request.resource.data) || request.resource.data.renewal_date is timestamp)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'renewal_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'billing_cycle',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'notes',
            'attached_documents'
          ])
          && isValidBaseRecordUpdate(request.resource.data, resource.data)
          && (!('renewal_date' in request.resource.data) || request.resource.data.renewal_date is timestamp)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow delete: if false;
      }

      match /report_exports/{exportId} {
        // Metadata for a confirmed Reports & Exports run. Stores period,
        // formats, included sections, record counts, warning counts, and
        // (for YTD/YoY) the resolved report scope. Must never contain
        // row-level financial data or CSV content.
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'report_type',
            'report_scope',
            'period_start',
            'period_end',
            'formats',
            'status',
            'included_sections',
            'record_counts',
            'warning_counts',
            'limitations',
            'created_at',
            'created_by'
          ])
          && request.resource.data.report_type is string
          && request.resource.data.report_type.size() > 0
          && request.resource.data.report_type.size() <= 80
          && request.resource.data.created_by == request.auth.uid
          && request.resource.data.created_at == request.time
          && request.resource.data.formats is list
          && request.resource.data.status is string
          && request.resource.data.included_sections is list
          && request.resource.data.record_counts is map
          && request.resource.data.warning_counts is map
          && request.resource.data.limitations is list
          && (!('report_scope' in request.resource.data) || request.resource.data.report_scope is map);
        allow update, delete: if false;
      }

      match /audit_logs/{auditLogId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'actor_uid',
            'actor_role',
            'action',
            'target_collection',
            'target_id',
            'before',
            'after',
            'reason',
            'source',
            'created_at'
          ])
          && isValidAuditLog(request.resource.data);
        allow update, delete: if false;
      }

      match /documents/{documentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidDocumentMetadata(request.resource.data)
          && request.resource.data.created_at == request.time
          && request.resource.data.updated_at == request.time
          && request.resource.data.storage_path.matches('users/' + userId + '/documents/.*');
        allow update: if isOwner(userId)
          && isValidDocumentMetadata(request.resource.data)
          && request.resource.data.created_at == resource.data.created_at
          && request.resource.data.updated_at == request.time
          && request.resource.data.storage_path == resource.data.storage_path;
        allow delete: if false;
      }

      match /ai_chats/{chatId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidAIChatCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidAIChatUpdate(request.resource.data, resource.data);
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidAIChatMessage(request.resource.data);
          allow update, delete: if false;
        }
      }

      match /usage_limits/{limitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && (isValidTrialAIUsageCreate(limitId, request.resource.data)
            || isValidPlanAIUsageCreate(limitId, userId, request.resource.data));
        allow update: if isOwner(userId)
          && (isValidTrialAIUsageUpdate(limitId, request.resource.data, resource.data)
            || isValidPlanAIUsageUpdate(limitId, userId, request.resource.data, resource.data));
        allow delete: if false;
      }

      match /settings/{settingsDoc} {
        allow read: if isOwner(userId)
          && settingsDoc in ['company', 'finance', 'import_rules', 'ai', 'whatsapp', 'reports', 'email_preferences'];
        allow create, update: if isOwner(userId)
          && isValidSettingsDoc(settingsDoc, request.resource.data);
        allow delete: if false;
      }

      match /onboarding/{onboardingDoc} {
        allow read: if isOwner(userId)
          && onboardingDoc in ['progress', 'profile', 'documents'];
        allow create, update: if isOwner(userId)
          && onboardingDoc in ['progress', 'profile', 'documents'];
        allow delete: if false;
      }

      match /bank_accounts/{bankAccountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBankAccountCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidBankAccountUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      match /bank_balance_snapshots/{snapshotId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBankBalanceSnapshot(request.resource.data);
        allow update, delete: if false;
      }

      match /bank_statement_imports/{importId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBankStatementImportCreate(userId, request.resource.data);
        allow update: if isOwner(userId)
          && isValidBankStatementImportUpdate(userId, request.resource.data, resource.data);
        allow delete: if false;

        match /rows/{rowId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidBankStatementRow(request.resource.data)
            && request.resource.data.created_at == request.time;
          allow update: if isOwner(userId)
            && isValidBankStatementRow(request.resource.data)
            && request.resource.data.created_at == resource.data.created_at;
          allow delete: if false;
        }
      }

      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBudgetCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidBudgetUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      match /budget_allocations/{allocationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBudgetAllocationCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidBudgetAllocationUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      // Invoices (Create Invoice MVP) — owner-scoped customer invoices.
      // Delete is blocked: invoices are voided (status update), never removed.
      // Finalizing never creates a transaction; receivables stay expected-only.
      match /invoices/{invoiceId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidInvoiceCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidInvoiceUpdate(request.resource.data, resource.data);
        allow delete: if false;

        match /items/{itemId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidInvoiceItem(request.resource.data)
            && request.resource.data.created_at == request.time
            && request.resource.data.updated_at == request.time
            && invoiceIsDraftAfterWrite(userId, invoiceId);
          allow update: if isOwner(userId)
            && isValidInvoiceItem(request.resource.data)
            && request.resource.data.created_at == resource.data.created_at
            && request.resource.data.updated_at == request.time
            && invoiceIsDraftAfterWrite(userId, invoiceId);
          // Item rows may be removed only while the invoice is still a draft.
          allow delete: if isOwner(userId)
            && invoiceIsDraftAfterWrite(userId, invoiceId);
        }
      }

      match /platform_learning/{learningDoc} {
        allow read: if isOwner(userId) && learningDoc == 'state';
        allow create, update: if isOwner(userId)
          && learningDoc == 'state'
          && isValidPlatformLearningState(request.resource.data);
        allow delete: if false;
      }

      // Accounting Center (Phase 1) — saved account mappings only.
      // Enums/strings only; never store amounts or formatted currency here.
      match /accounting_mappings/{mappingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidAccountingMappingCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidAccountingMappingUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    // ===== Internal Operations Console (Phase 1 MVP) =====
    // MVP_INTERNAL_ONLY_TEMPORARY — these top-level collections are intentionally
    // open because the internal console authenticates with a client-side
    // credential gate, not a Firebase identity. This exposes internal operational
    // metadata (no financial ledger data) and MUST be replaced with Firebase
    // custom claims or a backend-verified admin session before production.
    // See docs/internal_operations_console_plan.md §16 and §20.
    match /internal_users/{internalUserId} {
      allow read: if true;
      allow create, update: if isValidInternalUser(request.resource.data);
      allow delete: if false;
    }

    // Public Contact Sales leads. Written ONLY by the Admin SDK (the
    // submit-contact-sales Netlify function), which bypasses rules — so all
    // client writes are denied, keeping the public collection spam-proof. Read
    // is open for the credential-gated Internal Operations Console (Sales Leads
    // tab), same MVP_INTERNAL_ONLY posture as internal_users.
    match /sales_leads/{leadId} {
      allow read: if true;
      // Lead content is written ONLY by the Admin SDK (function) — create/delete
      // stay denied so the public collection can't be spammed or wiped. The
      // credential-gated console may flip ONLY the workflow status on an
      // existing lead; all core fields are immutable.
      allow create, delete: if false;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'status_updated_at'])
        && request.resource.data.status in ['new', 'contacted', 'closed', 'spam'];
    }

    match /outreach_leads/{leadId} {
      allow read: if true;
      allow create, update: if isValidOutreachLead(request.resource.data);
      allow delete: if true;
    }

    // Weekly digest broadcast jobs (internal-console "Send digest now"). The
    // console writes a pending job; the Netlify worker (Admin SDK + OpenAI)
    // executes it. MVP_INTERNAL_ONLY_TEMPORARY — open + field-validated, like
    // internal_users. The worker can only send the legit weekly digest (deduped
    // per ISO week), so the abuse ceiling is "trigger this week's digest early".
    match /internal_digest_jobs/{jobId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly([
            'mode', 'status', 'requested_by', 'requested_at', 'started_at', 'finished_at', 'result', 'error'
          ])
        && request.resource.data.mode in ['dryRun', 'send']
        && request.resource.data.status in ['pending', 'processing', 'done', 'failed']
        && request.resource.data.requested_by is string
        && request.resource.data.requested_by.size() <= 80
        && (request.resource.data.error == null
          || (request.resource.data.error is string && request.resource.data.error.size() <= 500));
      allow delete: if false;
    }

    match /internal_audit_logs/{auditLogId} {
      allow read: if true;
      allow create: if request.resource.data.source == 'internal_dashboard'
        && request.resource.data.action is string
        && request.resource.data.action.size() > 0
        && request.resource.data.action.size() <= 80
        && request.resource.data.target_user_id is string
        && request.resource.data.target_user_id.size() <= 160
        && request.resource.data.created_at == request.time
        && (!('reason' in request.resource.data) || request.resource.data.reason == null
          || (request.resource.data.reason is string && request.resource.data.reason.size() <= 500));
      allow update, delete: if false;
    }

    // ===== Voucher codes (checkout discounts, internal-console managed) =====
    // MVP_INTERNAL_ONLY_TEMPORARY — like internal_users above, admin writes are
    // field-validated but NOT identity-gated, because the internal console has
    // no Firebase identity. Known gaps until custom-claims admin auth exists:
    //   - anyone who knows the paths can create/disable/delete vouchers or read
    //     redemptions (no financial gain: checkout math is still enforced by
    //     hasValidPaymentRequestVoucher against the voucher doc itself, and
    //     delete is no worse than the already-open disable — both only stop a
    //     code working at checkout; past voucher_redemptions are immutable);
    //   - any signed-in user can burn redemption slots via the bare +1 counter
    //     update (DoS on limited vouchers, never a bigger discount).

    // Doc ID == the normalized uppercase code, so codes are unique by
    // construction and checkout can validate with a single get() while `list`
    // stays denied (no enumeration via queries).
    function isValidVoucherCodeCreate(code, data) {
      return code.matches('^[A-Z0-9_-]{4,32}$')
        && data.keys().hasAll([
          'code', 'discount_type', 'discount_value', 'status',
          'max_redemptions', 'redemption_count', 'valid_from', 'valid_until',
          'allowed_plan_ids', 'allowed_billing_frequencies',
          'created_by', 'created_at', 'updated_at',
          'disabled_at', 'disabled_by', 'notes'
        ])
        && data.keys().hasOnly([
          'code', 'discount_type', 'discount_value', 'status',
          'max_redemptions', 'redemption_count', 'valid_from', 'valid_until',
          'allowed_plan_ids', 'allowed_billing_frequencies',
          'created_by', 'created_at', 'updated_at',
          'disabled_at', 'disabled_by', 'notes'
        ])
        && data.code == code
        && data.discount_type == 'percentage'
        && data.discount_value is int
        && data.discount_value >= 1
        && data.discount_value <= 100
        && data.status == 'active'
        && (data.max_redemptions == null
          || (data.max_redemptions is int && data.max_redemptions >= 1 && data.max_redemptions <= 100000))
        && data.redemption_count == 0
        && (data.valid_from == null || data.valid_from is timestamp)
        && (data.valid_until == null || data.valid_until is timestamp)
        && (data.valid_from == null || data.valid_until == null || data.valid_until > data.valid_from)
        && (data.allowed_plan_ids == null
          || (data.allowed_plan_ids is list
            && data.allowed_plan_ids.size() >= 1
            && data.allowed_plan_ids.hasOnly(['starter', 'core', 'growth', 'enterprise'])))
        && (data.allowed_billing_frequencies == null
          || (data.allowed_billing_frequencies is list
            && data.allowed_billing_frequencies.size() >= 1
            && data.allowed_billing_frequencies.hasOnly(['monthly', 'annually'])))
        && data.created_by is string
        && data.created_by.size() > 0
        && data.created_by.size() <= 80
        && data.created_at == request.time
        && data.updated_at == request.time
        && data.disabled_at == null
        && data.disabled_by == null
        && (data.notes == null || (data.notes is string && data.notes.size() <= 500));
    }

    // Checkout-side counter bump: only the counter (+updated_at) may change,
    // exactly +1, never past the cap, only while active. The bump itself is
    // tied to a real redemption by hasValidPaymentRequestVoucher in the same
    // commit (see the counter-burn caveat in the banner above).
    function isVoucherRedemptionIncrement(prev, next) {
      return request.auth != null
        && next.diff(prev).affectedKeys().hasOnly(['redemption_count', 'updated_at'])
        && next.redemption_count == prev.redemption_count + 1
        && (prev.max_redemptions == null || next.redemption_count <= prev.max_redemptions)
        && prev.status == 'active'
        && next.updated_at == request.time;
    }

    // Internal-console lifecycle edits. Code, discount percent, and the
    // redemption counter are immutable here; disabling must stamp who/when.
    function isValidVoucherAdminUpdate(prev, next) {
      return next.diff(prev).affectedKeys().hasOnly([
          'status', 'max_redemptions', 'valid_until', 'notes',
          'disabled_at', 'disabled_by', 'updated_at'
        ])
        && next.status in ['active', 'disabled', 'expired']
        && (
          next.status == prev.status
          || (next.status == 'disabled'
            && next.disabled_at == request.time
            && next.disabled_by is string
            && next.disabled_by.size() > 0
            && next.disabled_by.size() <= 80)
          || (next.status == 'active' && prev.status == 'disabled')
        )
        && (next.max_redemptions == null
          || (next.max_redemptions is int
            && next.max_redemptions >= 1
            && next.max_redemptions <= 100000
            && next.max_redemptions >= next.redemption_count))
        && (next.valid_until == null || next.valid_until is timestamp)
        && (next.notes == null || (next.notes is string && next.notes.size() <= 500))
        && next.updated_at == request.time;
    }

    match /voucher_codes/{voucherCode} {
      allow get: if true;
      allow list: if false;
      allow create: if isValidVoucherCodeCreate(voucherCode, request.resource.data);
      allow update: if isVoucherRedemptionIncrement(resource.data, request.resource.data)
        || isValidVoucherAdminUpdate(resource.data, request.resource.data);
      // Internal-console hard delete (MVP-open, same posture as create/disable
      // above). The console also arrayRemoves the code from voucher_code_index
      // in the same batch via the existing update rule.
      allow delete: if true;
    }

    // Registry of existing codes so the internal console can list vouchers
    // without a (denied) collection query. Maintained via arrayUnion in the
    // same batch as each voucher create.
    match /voucher_code_index/{indexId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if indexId == 'registry'
        && request.resource.data.keys().hasOnly(['codes', 'updated_at'])
        && request.resource.data.codes is list
        && request.resource.data.codes.size() <= 500
        && request.resource.data.updated_at == request.time;
      allow delete: if false;
    }

    // One redemption per payment request (doc ID == the payment request ID).
    // Created only inside the checkout commit; its amounts must mirror the
    // payment request written in the SAME commit, so it doubles as the
    // tamper-proof redemption audit record.
    function isValidVoucherRedemptionCreate(redemptionId, data) {
      // `let` keeps the expression budget low (see hasAppliedPaymentRequestVoucher).
      // Unauthenticated requests error on request.auth.uid in the path → deny.
      let requestAfter = getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/billing_payment_requests/$(redemptionId)).data;
      return request.auth != null
        && data.keys().hasAll([
          'voucher_id', 'code', 'user_id', 'checkout_session_id',
          'plan_id', 'billing_frequency',
          'original_amount', 'discount_amount', 'final_amount', 'currency',
          'status', 'created_at', 'redeemed_at'
        ])
        && data.keys().hasOnly([
          'voucher_id', 'code', 'user_id', 'checkout_session_id',
          'plan_id', 'billing_frequency',
          'original_amount', 'discount_amount', 'final_amount', 'currency',
          'status', 'created_at', 'redeemed_at'
        ])
        && data.voucher_id is string
        && data.voucher_id.matches('^[A-Z0-9_-]{4,32}$')
        && data.code == data.voucher_id
        && data.user_id == request.auth.uid
        && data.checkout_session_id == redemptionId
        && data.plan_id in ['starter', 'core', 'growth', 'enterprise']
        && data.billing_frequency in ['monthly', 'annually']
        && data.original_amount is number
        && data.original_amount > 0
        && data.discount_amount is number
        && data.discount_amount >= 0
        && data.final_amount is number
        && data.final_amount >= 0
        && data.currency == 'IDR'
        && data.status == 'reserved'
        && data.created_at == request.time
        && data.redeemed_at == null
        && requestAfter.voucher_id == data.voucher_id
        && requestAfter.plan_id == data.plan_id
        && requestAfter.billing_frequency == data.billing_frequency
        && requestAfter.subtotal_amount == data.original_amount
        && requestAfter.voucher_discount_amount == data.discount_amount
        && requestAfter.total_amount == data.final_amount;
    }

    // Internal-console resolution after manual payment review. No Firebase
    // identity exists on the console (see banner), so this is open like
    // internal_users; the transition matrix is the only protection.
    function isValidVoucherRedemptionStatusUpdate(prev, next) {
      return prev.status == 'reserved'
        && next.status in ['redeemed', 'cancelled']
        && next.diff(prev).affectedKeys().hasOnly(['status', 'redeemed_at'])
        && (next.status != 'redeemed' || next.redeemed_at == request.time)
        && (next.status != 'cancelled' || next.redeemed_at == null);
    }

    match /voucher_redemptions/{redemptionId} {
      allow read: if true;
      allow create: if isValidVoucherRedemptionCreate(redemptionId, request.resource.data);
      allow update: if isValidVoucherRedemptionStatusUpdate(resource.data, request.resource.data);
      allow delete: if false;
    }

    // ========================================================================
    // WORKSPACES — Team Management & RBAC (see docs/SECURITY_SYSTEM.md §3–6)
    //
    // Seeding rule: for existing single-user accounts workspaceId == owner uid.
    // STAGE 1 (this block) governs the workspace profile, membership, invites,
    // and workspace-scoped audit logs — the team-management feature. The finance
    // collections (transactions/bills/budgets/…) still live under users/{uid}
    // and migrate to workspaces/{workspaceId}/<collection> in STAGE 2; their
    // role-gated rules are added there alongside the data migration.
    // ========================================================================

    function memberPath(workspaceId, uid) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid);
    }
    function callerMember(workspaceId) {
      return get(memberPath(workspaceId, request.auth.uid)).data;
    }
    function isMember(workspaceId) {
      return isSignedIn()
        && exists(memberPath(workspaceId, request.auth.uid))
        && callerMember(workspaceId).status == 'active';
    }
    function hasRole(workspaceId, roles) {
      return isMember(workspaceId) && (callerMember(workspaceId).role in roles);
    }
    // Email-keyed invites: doc id == lowercased invitee email, so rules can
    // verify a self-join without a query.
    function callerEmail() {
      return (request.auth != null && request.auth.token.email is string)
        ? request.auth.token.email.lower() : '';
    }
    function invitePathFor(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(callerEmail());
    }
    function hasPendingInvite(workspaceId) {
      return callerEmail() != ''
        && exists(invitePathFor(workspaceId))
        && get(invitePathFor(workspaceId)).data.status == 'pending';
    }
    function pendingInviteRole(workspaceId) {
      return get(invitePathFor(workspaceId)).data.role;
    }

    function isValidWorkspaceProfile(data) {
      return data.keys().hasOnly(['owner_uid', 'name', 'created_at', 'updated_at'])
        && data.owner_uid is string
        && (!('name' in data) || data.name == null || (data.name is string && data.name.size() <= 120));
    }
    function isValidMember(data) {
      return data.keys().hasOnly(['uid', 'email', 'display_name', 'role', 'status', 'invited_by', 'joined_at', 'updated_at'])
        && data.uid is string
        && data.role in ['owner', 'admin', 'finance', 'viewer']
        && data.status in ['active', 'pending', 'removed']
        && (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 200))
        && (!('display_name' in data) || data.display_name == null || (data.display_name is string && data.display_name.size() <= 200))
        && (!('invited_by' in data) || data.invited_by == null || (data.invited_by is string && data.invited_by.size() <= 160));
    }
    function isValidInvite(inviteId, data) {
      return data.keys().hasOnly(['email', 'role', 'status', 'invited_by', 'invited_by_email', 'created_at', 'updated_at', 'expires_at', 'accepted_by', 'accepted_at'])
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.email == inviteId
        && data.role in ['admin', 'finance', 'viewer']
        && data.status in ['pending', 'accepted', 'revoked', 'expired']
        && (!('invited_by' in data) || data.invited_by == null || (data.invited_by is string && data.invited_by.size() <= 160))
        && (!('invited_by_email' in data) || data.invited_by_email == null || (data.invited_by_email is string && data.invited_by_email.size() <= 200))
        && (!('expires_at' in data) || data.expires_at == null || data.expires_at is timestamp);
    }
    function isValidWorkspaceAuditLog(data) {
      return data.keys().hasAll(['actor_uid', 'action', 'target_collection', 'target_id', 'source', 'created_at'])
        && data.actor_uid == request.auth.uid
        && data.action is string && data.action.size() > 0 && data.action.size() <= 80
        && data.target_collection in [
          'transactions', 'bills', 'subscriptions', 'vendors', 'budgets',
          'budget_allocations', 'invoices', 'exports', 'report_exports',
          'members', 'invites', 'workspace', 'settings', 'integrations', 'users',
          'onboarding', 'bank_accounts', 'bank_balance_snapshots',
          'bank_statement_imports', 'documents', 'billing',
          'billing_payment_requests', 'payment_verifications', 'accounting_mappings'
        ]
        && data.target_id is string && data.target_id.size() <= 200
        && data.source in ['dashboard', 'ai', 'integration', 'system']
        && data.created_at == request.time;
    }

    // ---- STAGE 2 finance-record validation (workspace scope) ----
    // Reuse the pure field validators defined above; for the collections whose
    // user-scoped blocks inline a keys().hasOnly([...]) allow-list, these helpers
    // hold a verbatim copy so the workspace blocks enforce identical shape.
    function invoiceIsDraftAfterWriteWs(workspaceId, invoiceId) {
      let inv = getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/invoices/$(invoiceId)).data;
      return inv.status == 'draft'
        || (inv.status == 'open' && (!('sent_at' in inv) || inv.sent_at == null));
    }
    function wsValidTxCreate(data) {
      return data.keys().hasOnly([
          'amount', 'vendor_name', 'category', 'type', 'status', 'icon', 'timestamp',
          'created_at', 'receipt_url', 'attached_documents', 'source', 'created_via',
          'extraction_status', 'extraction_source', 'extraction_confidence', 'extraction_warnings',
          'document_type', 'invoice_number', 'invoice_date', 'raw_text_preview',
          'source_file_name', 'source_file_mime_type', 'source_file_size_bytes',
          'payment_reference', 'notes', 'budget_id', 'budget_allocation_id', 'budget_match_method',
          'budget_match_status', 'budget_match_confidence', 'budget_assignment_reason',
          'budget_assignment_updated_at', 'budget_assignment_updated_by', 'budget_exclusion_reason',
          'cash_effective', 'cash_status', 'cash_direction', 'cash_account_id', 'cash_source',
          'cash_match_status', 'cash_effective_at', 'bank_statement_import_id', 'bank_statement_row_id',
          'imported_at', 'bank_account_id', 'linked_bill_id'
        ])
        && isValidBaseRecord(data)
        && (!('created_at' in data) || data.created_at == request.time)
        && (!('receipt_url' in data) || data.receipt_url is string)
        && (!('linked_bill_id' in data) || data.linked_bill_id == null || (data.linked_bill_id is string && data.linked_bill_id.size() <= 120))
        && isValidTransactionBudgetFields(data)
        && isValidAttachedDocuments(data)
        && isValidAICaptureMetadata(data);
    }
    function wsValidTxUpdate(data, existingData) {
      return data.keys().hasOnly([
          'amount', 'vendor_name', 'category', 'type', 'status', 'icon', 'date', 'timestamp',
          'created_at', 'receipt_url', 'attached_documents', 'source', 'created_via',
          'extraction_status', 'extraction_source', 'extraction_confidence', 'extraction_warnings',
          'document_type', 'invoice_number', 'invoice_date', 'raw_text_preview',
          'source_file_name', 'source_file_mime_type', 'source_file_size_bytes',
          'payment_reference', 'notes', 'budget_id', 'budget_allocation_id', 'budget_match_method',
          'budget_match_status', 'budget_match_confidence', 'budget_assignment_reason',
          'budget_assignment_updated_at', 'budget_assignment_updated_by', 'budget_exclusion_reason',
          'cash_effective', 'cash_status', 'cash_direction', 'cash_account_id', 'cash_source',
          'cash_match_status', 'cash_effective_at', 'cash_assignment_reason', 'cash_assignment_updated_at',
          'cash_assignment_updated_by', 'updated_at', 'updated_by', 'is_voided', 'voided_at', 'voided_by',
          'void_reason', 'bank_statement_import_id', 'bank_statement_row_id', 'imported_at',
          'bank_account_id', 'linked_bill_id'
        ])
        && isValidTransactionRecordUpdate(data, existingData)
        && preservesLegacyRecordDate(data, existingData)
        && (!('linked_bill_id' in data) || data.linked_bill_id == null || (data.linked_bill_id is string && data.linked_bill_id.size() <= 120))
        && isValidTransactionBudgetFields(data)
        && isValidAttachedDocuments(data)
        && isValidAICaptureMetadata(data);
    }
    function wsValidBillCreate(data) {
      return data.keys().hasOnly([
          'amount', 'vendor_name', 'category', 'type', 'status', 'icon', 'timestamp', 'due_date',
          'source', 'created_via', 'extraction_status', 'extraction_source', 'extraction_confidence',
          'extraction_warnings', 'document_type', 'invoice_number', 'invoice_date', 'payment_status',
          'raw_text_preview', 'source_file_name', 'source_file_mime_type', 'source_file_size_bytes',
          'attached_documents', 'invoice_status', 'budget_id', 'budget_allocation_id',
          'budget_match_method', 'budget_match_status', 'budget_impact_status', 'budget_assignment_reason',
          'budget_assignment_updated_at', 'budget_assignment_updated_by', 'budget_exclusion_reason'
        ])
        && isValidBaseRecord(data)
        && (!('due_date' in data) || data.due_date is timestamp)
        && (!('payment_status' in data) || data.payment_status in ['unpaid', 'paid', 'overdue', 'unknown'])
        && (!('invoice_status' in data) || data.invoice_status in ['attached'])
        && isValidBillBudgetFields(data)
        && isValidAttachedDocuments(data)
        && isValidAICaptureMetadata(data);
    }
    function wsValidBillUpdate(data, existingData) {
      return data.keys().hasOnly([
          'amount', 'vendor_name', 'category', 'type', 'status', 'icon', 'timestamp', 'date', 'due_date',
          'source', 'created_via', 'extraction_status', 'extraction_source', 'extraction_confidence',
          'extraction_warnings', 'document_type', 'invoice_number', 'invoice_date', 'payment_status',
          'raw_text_preview', 'source_file_name', 'source_file_mime_type', 'source_file_size_bytes',
          'attached_documents', 'invoice_status', 'budget_id', 'budget_allocation_id',
          'budget_match_method', 'budget_match_status', 'budget_impact_status', 'budget_assignment_reason',
          'budget_assignment_updated_at', 'budget_assignment_updated_by', 'budget_exclusion_reason',
          'linked_transaction_id', 'updated_at', 'updated_by'
        ])
        && isValidBaseRecordUpdate(data, existingData)
        && preservesLegacyRecordDate(data, existingData)
        && (!('due_date' in data) || data.due_date is timestamp)
        && (!('payment_status' in data) || data.payment_status in ['unpaid', 'paid', 'overdue', 'unknown'])
        && (!('invoice_status' in data) || data.invoice_status in ['attached'])
        && (!('linked_transaction_id' in data) || data.linked_transaction_id == null || (data.linked_transaction_id is string && data.linked_transaction_id.size() <= 120))
        && isValidBillBudgetFields(data)
        && isValidAttachedDocuments(data)
        && isValidAICaptureMetadata(data);
    }
    function wsValidSubCreate(data) {
      return data.keys().hasOnly([
          'amount', 'vendor_name', 'category', 'type', 'status', 'icon', 'timestamp', 'renewal_date',
          'source', 'created_via', 'extraction_status', 'extraction_source', 'extraction_confidence',
          'extraction_warnings', 'document_type', 'invoice_number', 'invoice_date', 'billing_cycle',
          'raw_text_preview', 'source_file_name', 'source_file_mime_type', 'source_file_size_bytes',
          'notes', 'attached_documents'
        ])
        && isValidBaseRecord(data)
        && (!('renewal_date' in data) || data.renewal_date is timestamp)
        && isValidAttachedDocuments(data)
        && isValidAICaptureMetadata(data);
    }
    function wsValidSubUpdate(data, existingData) {
      return data.keys().hasOnly([
          'amount', 'vendor_name', 'category', 'type', 'status', 'icon', 'timestamp', 'renewal_date',
          'source', 'created_via', 'extraction_status', 'extraction_source', 'extraction_confidence',
          'extraction_warnings', 'document_type', 'invoice_number', 'invoice_date', 'billing_cycle',
          'raw_text_preview', 'source_file_name', 'source_file_mime_type', 'source_file_size_bytes',
          'notes', 'attached_documents'
        ])
        && isValidBaseRecordUpdate(data, existingData)
        && (!('renewal_date' in data) || data.renewal_date is timestamp)
        && isValidAttachedDocuments(data)
        && isValidAICaptureMetadata(data);
    }
    function wsValidReportExportCreate(data) {
      return data.keys().hasOnly([
          'report_type', 'report_scope', 'period_start', 'period_end', 'formats', 'status',
          'included_sections', 'record_counts', 'warning_counts', 'limitations', 'created_at', 'created_by'
        ])
        && data.report_type is string && data.report_type.size() > 0 && data.report_type.size() <= 80
        && data.created_by == request.auth.uid
        && data.created_at == request.time
        && data.formats is list
        && data.status is string
        && data.included_sections is list
        && data.record_counts is map
        && data.warning_counts is map
        && data.limitations is list
        && (!('report_scope' in data) || data.report_scope is map);
    }

    match /workspaces/{workspaceId} {
      // Members can read the workspace; an owner can also read their own (id==uid)
      // workspace to bootstrap it before their member doc exists.
      allow read: if isMember(workspaceId)
        || (isSignedIn() && workspaceId == request.auth.uid);
      // Bootstrap: a user may only create their own workspace (id == uid).
      allow create: if isSignedIn()
        && workspaceId == request.auth.uid
        && isValidWorkspaceProfile(request.resource.data)
        && request.resource.data.owner_uid == request.auth.uid
        && request.resource.data.created_at == request.time;
      // Owner/admin may edit the profile; owner_uid is immutable.
      allow update: if hasRole(workspaceId, ['owner', 'admin'])
        && isValidWorkspaceProfile(request.resource.data)
        && request.resource.data.owner_uid == resource.data.owner_uid;
      // Workspace deletion is an owner-only sensitive action handled server-side.
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isMember(workspaceId)
          || (isSignedIn() && workspaceId == request.auth.uid && memberId == request.auth.uid);
        // (a) Owner bootstrap of their own membership.
        allow create: if isSignedIn()
          && workspaceId == request.auth.uid
          && memberId == request.auth.uid
          && isValidMember(request.resource.data)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'owner'
          && request.resource.data.status == 'active'
        // (b) Owner/admin adds a member directly (never another owner).
          || hasRole(workspaceId, ['owner', 'admin'])
          && isValidMember(request.resource.data)
          && request.resource.data.uid == memberId
          && request.resource.data.role in ['admin', 'finance', 'viewer']
        // (c) Invite acceptance: the invitee self-joins from a pending invite
          || isSignedIn()
          && memberId == request.auth.uid
          && isValidMember(request.resource.data)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == 'active'
          && hasPendingInvite(workspaceId)
          && request.resource.data.role == pendingInviteRole(workspaceId);
        // Owner/admin change role/status; cannot edit an owner member unless owner,
        // and cannot promote anyone to owner (ownership transfer is server-side).
        allow update: if hasRole(workspaceId, ['owner', 'admin'])
          && isValidMember(request.resource.data)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role != 'owner'
          && resource.data.role != 'owner';
        // Owner/admin remove a non-owner; a member may remove themselves.
        allow delete: if (hasRole(workspaceId, ['owner', 'admin']) && resource.data.role != 'owner')
          || (isSignedIn() && memberId == request.auth.uid && resource.data.role != 'owner');
      }

      match /invites/{inviteId} {
        // Owner/admin manage invites; an invitee may read their own invite by id.
        allow read: if hasRole(workspaceId, ['owner', 'admin'])
          || (isSignedIn() && resource.data.email == callerEmail());
        allow create: if hasRole(workspaceId, ['owner', 'admin'])
          && isValidInvite(inviteId, request.resource.data)
          && request.resource.data.status == 'pending'
          && request.resource.data.created_at == request.time;
        // Owner/admin update (revoke/resend); OR the invitee flips pending->accepted.
        allow update: if (hasRole(workspaceId, ['owner', 'admin'])
            && isValidInvite(inviteId, request.resource.data))
          || (isSignedIn()
            && resource.data.email == callerEmail()
            && resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'accepted_by', 'accepted_at', 'updated_at'])
            && request.resource.data.accepted_by == request.auth.uid);
        allow delete: if hasRole(workspaceId, ['owner', 'admin']);
      }

      match /audit_logs/{auditLogId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin']);
        allow create: if isMember(workspaceId)
          && isValidWorkspaceAuditLog(request.resource.data);
        allow update, delete: if false;
      }

      // ---- STAGE 2 finance/operational records (role-gated) ----
      // read: any active member incl. viewer · create/update: owner/admin/finance
      // · delete/void: owner/admin (most use status changes, not deletes).
      match /transactions/{transactionId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidTxCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidTxUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
      match /bills/{billId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidBillCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidBillUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
      match /subscriptions/{subscriptionId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidSubCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidSubUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
      match /budgets/{budgetId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBudgetCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBudgetUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
      match /budget_allocations/{allocationId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBudgetAllocationCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBudgetAllocationUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
      match /invoices/{invoiceId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidInvoiceCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidInvoiceUpdate(request.resource.data, resource.data);
        allow delete: if false;

        match /items/{itemId} {
          allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
          allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
            && isValidInvoiceItem(request.resource.data)
            && request.resource.data.created_at == request.time
            && request.resource.data.updated_at == request.time
            && invoiceIsDraftAfterWriteWs(workspaceId, invoiceId);
          allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
            && isValidInvoiceItem(request.resource.data)
            && request.resource.data.created_at == resource.data.created_at
            && request.resource.data.updated_at == request.time
            && invoiceIsDraftAfterWriteWs(workspaceId, invoiceId);
          allow delete: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
            && invoiceIsDraftAfterWriteWs(workspaceId, invoiceId);
        }
      }
      match /bank_accounts/{bankAccountId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBankAccountCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBankAccountUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
      match /bank_balance_snapshots/{snapshotId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidBankBalanceSnapshot(request.resource.data);
        allow update, delete: if false;
      }
      match /bank_statement_imports/{importId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
          && isValidBankStatementImport(request.resource.data)
          && request.resource.data.created_at == request.time
          && request.resource.data.updated_at == request.time;
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
          && isValidBankStatementImport(request.resource.data)
          && request.resource.data.created_at == resource.data.created_at;
        allow delete: if false;

        match /rows/{rowId} {
          allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
          allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
            && isValidBankStatementRow(request.resource.data)
            && request.resource.data.created_at == request.time;
          allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
            && isValidBankStatementRow(request.resource.data)
            && request.resource.data.created_at == resource.data.created_at;
          allow delete: if false;
        }
      }
      match /documents/{documentId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
          && isValidDocumentMetadata(request.resource.data)
          && request.resource.data.created_at == request.time
          && request.resource.data.updated_at == request.time
          && request.resource.data.storage_path.matches('(users|workspaces)/.*/documents/.*');
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance'])
          && isValidDocumentMetadata(request.resource.data)
          && request.resource.data.created_at == resource.data.created_at
          && request.resource.data.updated_at == request.time
          && request.resource.data.storage_path == resource.data.storage_path;
        allow delete: if false;
      }
      match /report_exports/{exportId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && wsValidReportExportCreate(request.resource.data);
        allow update, delete: if false;
      }
      match /accounting_mappings/{mappingId} {
        allow read: if hasRole(workspaceId, ['owner', 'admin', 'finance', 'viewer']);
        allow create: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidAccountingMappingCreate(request.resource.data);
        allow update: if hasRole(workspaceId, ['owner', 'admin', 'finance']) && isValidAccountingMappingUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }
    }

    // Reverse lookup: a user may read/write only their own pointer doc.
    match /user_workspaces/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidBaseRecord(data) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp is timestamp;
    }

    function isValidBaseRecordUpdate(data, existingData) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp == existingData.timestamp;
    }

    function isValidTransactionRecordUpdate(data, existingData) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled', 'Voided']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp is timestamp
        && (!('created_at' in data) || data.created_at == existingData.created_at)
        && (!('updated_at' in data) || data.updated_at == request.time)
        && (!('updated_by' in data) || data.updated_by == request.auth.uid)
        && (!('is_voided' in data) || data.is_voided is bool)
        && (!('voided_at' in data) || data.voided_at == request.time)
        && (!('voided_by' in data) || data.voided_by == request.auth.uid)
        && (!('void_reason' in data) || (data.void_reason is string && data.void_reason.size() > 0 && data.void_reason.size() <= 500))
        && (!(data.status == 'Voided') || (
          data.is_voided == true
          && data.voided_at == request.time
          && data.voided_by == request.auth.uid
          && data.void_reason is string
          && data.void_reason.size() > 0
          && data.void_reason.size() <= 500
        ));
    }

    function isValidAICaptureMetadata(data) {
      return (!('source' in data) || data.source in ['bill_scan', 'transaction_scan', 'subscription_scan'])
        && (!('created_via' in data) || data.created_via in ['ai_bill_capture', 'ai_transaction_capture', 'ai_subscription_capture'])
        && (!('extraction_status' in data) || data.extraction_status == 'reviewed')
        && (!('extraction_source' in data) || data.extraction_source is string)
        && (!('extraction_confidence' in data) || data.extraction_confidence == null || data.extraction_confidence is number)
        && (!('extraction_warnings' in data) || data.extraction_warnings is list)
        && (!('document_type' in data) || data.document_type is string)
        && (!('invoice_number' in data) || data.invoice_number == null || data.invoice_number is string)
        && (!('invoice_date' in data) || data.invoice_date is timestamp)
        && (!('raw_text_preview' in data) || data.raw_text_preview == null || (data.raw_text_preview is string && data.raw_text_preview.size() <= 500))
        && (!('source_file_name' in data) || data.source_file_name == null || data.source_file_name is string)
        && (!('source_file_mime_type' in data) || data.source_file_mime_type == null || data.source_file_mime_type is string)
        && (!('source_file_size_bytes' in data) || data.source_file_size_bytes == null || data.source_file_size_bytes is number)
        && (!('payment_reference' in data) || data.payment_reference == null || data.payment_reference is string)
        && (!('notes' in data) || data.notes == null || data.notes is string)
        && (!('billing_cycle' in data) || data.billing_cycle in ['monthly', 'annual', 'weekly', 'quarterly', 'unknown']);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll([
          'actor_uid',
          'action',
          'target_collection',
          'target_id',
          'source',
          'created_at'
        ])
        && data.actor_uid == request.auth.uid
        && data.action is string
        && data.action.size() > 0
        && data.action.size() <= 80
        && data.target_collection in [
          'transactions',
          'bills',
          'subscriptions',
          'vendors',
          'budgets',
          'budget_allocations',
          'integrations',
          'exports',
          'report_exports',
          'users',
          'onboarding',
          'bank_accounts',
          'bank_balance_snapshots',
          'bank_statement_imports',
          'documents',
          'billing',
          'billing_payment_requests',
          'payment_verifications',
          'accounting_mappings'
        ]
        && data.target_id is string
        && data.target_id.size() <= 160
        && data.source in ['dashboard', 'ai', 'integration', 'system', 'onboarding']
        && data.created_at == request.time;
    }

    // Accounting Center (Phase 1) — saved category/type → account mappings.
    // Strings/enums only. No money, no row-level financial data, no formatted
    // currency. See docs/PROJECT_BACKGROUND.md §4 (Accounting mappings).
    function isValidAccountingMapping(data) {
      return data.keys().hasOnly([
          'source_type',
          'source_value',
          'target_account_code',
          'target_account_name',
          'target_account_type',
          'confidence',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasAll([
          'source_type',
          'source_value',
          'target_account_code',
          'target_account_name',
          'target_account_type',
          'confidence',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.source_type in ['transaction_category', 'transaction_type']
        && data.source_value is string
        && data.source_value.size() > 0
        && data.source_value.size() <= 60
        && data.target_account_code is string
        && data.target_account_code.size() > 0
        && data.target_account_code.size() <= 12
        && data.target_account_name is string
        && data.target_account_name.size() > 0
        && data.target_account_name.size() <= 80
        && data.target_account_type in ['asset', 'liability', 'equity', 'revenue', 'expense', 'contra_revenue', 'contra_expense']
        && data.confidence in ['system_default', 'user_confirmed', 'ai_suggested']
        && data.status in ['active', 'archived'];
    }

    function isValidAccountingMappingCreate(data) {
      return isValidAccountingMapping(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidAccountingMappingUpdate(data, existingData) {
      return isValidAccountingMapping(data)
        && data.source_type == existingData.source_type
        && data.source_value == existingData.source_value
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    // Owner-scoped 3-day trial / billing access doc (users/{uid}/billing/access).
    // Status enums only — no secrets, no formatted currency strings.
    function isValidBillingAccess(data) {
      return (!('access_status' in data) || data.access_status in [
          'trial_not_started', 'trial_active', 'trial_expiring', 'trial_expired',
          'payment_pending', 'payment_submitted', 'payment_verified', 'active', 'suspended'
        ])
        && (!('payment_status' in data) || data.payment_status in [
          'not_started', 'pending', 'submitted', 'under_review', 'verified', 'rejected'
        ])
        && (!('account_status' in data) || data.account_status in ['trial', 'active', 'suspended'])
        && (!('trial_duration_days' in data) || data.trial_duration_days is number)
        && (!('plan_id' in data) || data.plan_id == null
          || (data.plan_id is string && data.plan_id.size() <= 40));
    }

    // Owner-scoped manual payment proof (users/{uid}/payment_verifications/{id}).
    // Raw-integer amounts only; no card data / secrets.
    function isValidPaymentVerification(data) {
      return data.amount is number && data.amount >= 0 && data.amount <= 999999999999
        && data.currency == 'IDR'
        && data.status in ['submitted', 'under_review', 'verified', 'rejected']
        && (!('payment_method' in data) || data.payment_method in ['bank_transfer', 'manual', 'other'])
        && (!('billing_period' in data) || data.billing_period == null
          || data.billing_period in ['monthly', 'annual', 'custom'])
        && (!('proof_file_name' in data) || data.proof_file_name == null
          || (data.proof_file_name is string && data.proof_file_name.size() <= 240))
        && (!('submitted_note' in data) || data.submitted_note == null
          || (data.submitted_note is string && data.submitted_note.size() <= 500));
    }

    function isValidBillingPlan(planId) {
      return planId in ['trial', 'core', 'growth', 'enterprise'];
    }

    function isValidBillingPlanName(planId, planName) {
      return (planId == 'trial' && planName == 'Trial')
        || (planId == 'core' && planName == 'Core Ops')
        || (planId == 'growth' && planName == 'Growth Engine')
        || (planId == 'enterprise' && planName == 'Enterprise AI');
    }

    function isValidBillingAmounts(data) {
      return (
          (data.plan_id == 'core' && data.billing_frequency == 'monthly' && data.subtotal_amount == 3500000)
          || (data.plan_id == 'core' && data.billing_frequency == 'annually' && data.subtotal_amount == 33480000)
          || (data.plan_id == 'growth' && data.billing_frequency == 'monthly' && data.subtotal_amount == 8500000)
          || (data.plan_id == 'growth' && data.billing_frequency == 'annually' && data.subtotal_amount == 81480000)
          || (data.plan_id == 'enterprise' && data.billing_frequency == 'monthly' && data.subtotal_amount == 18000000)
          || (data.plan_id == 'enterprise' && data.billing_frequency == 'annually' && data.subtotal_amount == 172680000)
        )
        && data.estimated_tax_amount == data.subtotal_amount * 11 / 100;
    }

    function isValidBillingFrequency(frequency) {
      return frequency == null || frequency in ['monthly', 'annually'];
    }

    function isValidBillingSubscription(data) {
      return data.keys().hasAll([
          'plan_id',
          'plan_name',
          'status',
          'billing_frequency',
          'current_payment_request_id',
          'trial_started_at',
          'trial_ends_at',
          'current_period_start',
          'current_period_end',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'plan_id',
          'plan_name',
          'status',
          'billing_frequency',
          'current_payment_request_id',
          'trial_started_at',
          'trial_ends_at',
          'current_period_start',
          'current_period_end',
          'updated_at'
        ])
        && isValidBillingPlan(data.plan_id)
        && isValidBillingPlanName(data.plan_id, data.plan_name)
        && data.status in ['trialing', 'awaiting_payment', 'pending_verification', 'active', 'past_due', 'expired', 'payment_failed']
        && isValidBillingFrequency(data.billing_frequency)
        && (data.current_payment_request_id == null || (data.current_payment_request_id is string && data.current_payment_request_id.size() <= 160))
        && (data.trial_started_at == null || data.trial_started_at is timestamp)
        && (data.trial_ends_at == null || data.trial_ends_at is timestamp)
        && (data.current_period_start == null || data.current_period_start is timestamp)
        && (data.current_period_end == null || data.current_period_end is timestamp)
        && data.updated_at == request.time;
    }

    function isValidBillingPaymentRequest(data) {
      return data.keys().hasAll([
          'plan_id',
          'plan_name',
          'billing_frequency',
          'subtotal_amount',
          'estimated_tax_amount',
          'total_amount',
          'currency',
          'payment_method',
          'payment_status',
          'provider',
          'provider_payment_id',
          'provider_invoice_url',
          'submitted_at',
          'verified_at',
          'failed_at',
          'expires_at',
          'user_confirmed_payment_at',
          'submitted_for_verification_at',
          'proof_document_id',
          'proof_file_name',
          'proof_uploaded_at',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'plan_id',
          'plan_name',
          'billing_frequency',
          'subtotal_amount',
          'estimated_tax_amount',
          'total_amount',
          'currency',
          'payment_method',
          'payment_status',
          'provider',
          'provider_payment_id',
          'provider_invoice_url',
          'submitted_at',
          'verified_at',
          'failed_at',
          'expires_at',
          'user_confirmed_payment_at',
          'submitted_for_verification_at',
          'proof_document_id',
          'proof_file_name',
          'proof_uploaded_at',
          'created_at',
          'updated_at'
        ])
        && data.plan_id in ['core', 'growth', 'enterprise']
        && isValidBillingPlanName(data.plan_id, data.plan_name)
        && data.billing_frequency in ['monthly', 'annually']
        && data.subtotal_amount is number
        && data.subtotal_amount > 0
        && data.estimated_tax_amount is number
        && data.estimated_tax_amount >= 0
        && data.total_amount is number
        && data.total_amount == data.subtotal_amount + data.estimated_tax_amount
        && isValidBillingAmounts(data)
        && data.currency == 'IDR'
        && data.payment_method in ['qris', 'va', 'card', 'invoice']
        // QRIS starts as awaiting_payment (pay the QR first); other methods submit
        // for verification immediately. verified/failed/expired stay server-owned.
        && data.payment_status in ['awaiting_payment', 'pending_verification']
        && data.provider == 'manual'
        && data.provider_payment_id == null
        && data.provider_invoice_url == null
        && data.submitted_at == request.time
        && data.verified_at == null
        && data.failed_at == null
        && data.expires_at == null
        && data.user_confirmed_payment_at == null
        && data.submitted_for_verification_at == null
        && data.proof_document_id == null
        && data.proof_file_name == null
        && data.proof_uploaded_at == null
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    // Owner-driven transition: a QRIS request moves awaiting_payment ->
    // pending_verification after the user confirms payment. Only the lifecycle
    // + optional proof-reference fields may change; amounts/plan/method are
    // immutable (guaranteed by the affectedKeys allow-list). The client can
    // never write verified/failed/expired here.
    function isValidPaymentRequestVerificationSubmit(prev, next) {
      return prev.payment_status == 'awaiting_payment'
        && next.payment_status == 'pending_verification'
        && next.diff(prev).affectedKeys().hasOnly([
          'payment_status',
          'user_confirmed_payment_at',
          'submitted_for_verification_at',
          'proof_document_id',
          'proof_file_name',
          'proof_uploaded_at',
          'updated_at'
        ])
        && next.user_confirmed_payment_at is timestamp
        && next.submitted_for_verification_at == request.time
        && next.updated_at == request.time
        && (
          (next.proof_document_id == null && next.proof_file_name == null && next.proof_uploaded_at == null)
          || (next.proof_document_id is string && next.proof_document_id.size() <= 160
            && next.proof_file_name is string && next.proof_file_name.size() <= 240
            && next.proof_uploaded_at is timestamp)
        );
    }

    function isCheckoutSubscriptionWrite(userId, data) {
      return data.status == 'pending_verification'
        && data.plan_id in ['core', 'growth', 'enterprise']
        && data.billing_frequency in ['monthly', 'annually']
        && data.current_payment_request_id is string
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.plan_id == data.plan_id
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.billing_frequency == data.billing_frequency
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.payment_status == 'pending_verification';
    }

    function hasRecentBillingPeriodStart(data) {
      return data.current_period_start is timestamp
        && data.current_period_start <= request.time
        && data.current_period_start >= request.time - duration.value(10, 'm');
    }

    function hasInternalVerifiedBillingPeriodStart(userId, data) {
      return get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_verified_at is timestamp
        && data.current_period_start == get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_verified_at;
    }

    function hasValidBillingPeriodWindow(data) {
      return data.current_period_start is timestamp
        && data.current_period_end is timestamp
        && data.current_period_end > data.current_period_start
        && (
          (data.billing_frequency == 'monthly'
            && data.current_period_end <= data.current_period_start + duration.value(32, 'd'))
          || (data.billing_frequency == 'annually'
            && data.current_period_end >= data.current_period_start + duration.value(360, 'd')
            && data.current_period_end <= data.current_period_start + duration.value(367, 'd'))
        );
    }

    function hasValidVerifiedBillingPeriod(userId, data) {
      return hasValidBillingPeriodWindow(data)
        && (hasInternalVerifiedBillingPeriodStart(userId, data) || hasRecentBillingPeriodStart(data));
    }

    function hasValidActiveReconcileFields(userId, prev, data) {
      return data.diff(prev).affectedKeys().hasOnly(['status', 'updated_at'])
        || (data.diff(prev).affectedKeys().hasOnly(['status', 'current_period_start', 'current_period_end', 'updated_at'])
          && prev.current_period_end == null
          && hasValidVerifiedBillingPeriod(userId, data));
    }

    // Owner carries a reviewer's verify/reject decision from the open
    // internal_users index into their canonical subscription. Verified payments
    // may also stamp current_period_start/current_period_end from the verified
    // billing frequency so settings can show the next billing date.
    // MVP/UX-only: internal_users is the credential-gated ops index; a trusted
    // backend should own this in production.
    function isInternalReviewReconcile(userId, prev, data) {
      return exists(/databases/$(database)/documents/internal_users/$(userId))
        && (
          // A verified payment is a definitive grant: promote to active from any
          // not-yet-active state (incl. expired/trialing). No updated_at race —
          // the automatic trial-expiry write bumps prev.updated_at after the
          // manual review, which must not strand an approved user.
          (data.status == 'active'
            && prev.status in ['pending_verification', 'awaiting_payment', 'expired', 'trialing']
            && hasValidActiveReconcileFields(userId, prev, data)
            && get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_status == 'verified')
          // Rejection only fails an in-flight payment and must be newer than the
          // subscription's own last write (never clobber a fresh retry).
          || (data.status == 'payment_failed'
            && data.diff(prev).affectedKeys().hasOnly(['status', 'updated_at'])
            && (prev.status == 'pending_verification' || prev.status == 'awaiting_payment')
            && get(/databases/$(database)/documents/internal_users/$(userId)).data.updated_at > prev.updated_at
            && get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_status == 'rejected')
        );
    }

    function isActiveBillingPeriodBackfill(userId, prev, data) {
      return exists(/databases/$(database)/documents/internal_users/$(userId))
        && prev.status == 'active'
        && data.status == 'active'
        && prev.current_period_end == null
        && get(/databases/$(database)/documents/internal_users/$(userId)).data.payment_status == 'verified'
        && data.diff(prev).affectedKeys().hasOnly(['current_period_start', 'current_period_end', 'updated_at'])
        && hasValidVerifiedBillingPeriod(userId, data);
    }

    // QRIS checkout: subscription moves to awaiting_payment alongside an
    // awaiting_payment request (cross-checked in the same commit).
    function isCheckoutAwaitingPaymentWrite(userId, data) {
      return data.status == 'awaiting_payment'
        && data.plan_id in ['core', 'growth', 'enterprise']
        && data.billing_frequency in ['monthly', 'annually']
        && data.current_payment_request_id is string
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.plan_id == data.plan_id
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.billing_frequency == data.billing_frequency
        && getAfter(/databases/$(database)/documents/users/$(userId)/billing_payment_requests/$(data.current_payment_request_id)).data.payment_status == 'awaiting_payment';
    }

    function isTrialSubscriptionCreate(data) {
      return data.status == 'trialing'
        && data.plan_id == 'trial'
        && data.plan_name == 'Trial'
        && data.billing_frequency == null
        && data.current_payment_request_id == null
        && data.trial_started_at is timestamp
        && data.trial_ends_at is timestamp
        && data.trial_started_at <= request.time
        && data.trial_ends_at == data.trial_started_at + duration.value(3, 'd')
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/onboarding/progress)
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)/onboarding/progress).data.onboarding_completed == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)/onboarding/progress).data.onboarding_exempt == true);
    }

    function isLegacyBillingMigration(userId, data) {
      return exists(/databases/$(database)/documents/users/$(userId)/billing/access)
        && data.trial_started_at == get(/databases/$(database)/documents/users/$(userId)/billing/access).data.trial_started_at
        && data.trial_ends_at == get(/databases/$(database)/documents/users/$(userId)/billing/access).data.trial_ends_at
        && (
          (data.status == 'active'
            && (get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status in ['active', 'payment_verified']
              || get(/databases/$(database)/documents/users/$(userId)/billing/access).data.payment_status == 'verified'))
          || (data.status == 'pending_verification'
            && (get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status == 'payment_submitted'
              || get(/databases/$(database)/documents/users/$(userId)/billing/access).data.payment_status in ['submitted', 'under_review']))
          || (data.status == 'payment_failed'
            && get(/databases/$(database)/documents/users/$(userId)/billing/access).data.payment_status == 'rejected')
          || (data.status == 'expired'
            && get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status == 'trial_expired')
          || (data.status == 'trialing'
            && get(/databases/$(database)/documents/users/$(userId)/billing/access).data.access_status in ['trial_active', 'trial_expiring'])
        );
    }

    // Internal Operations Console (Phase 1 MVP). Operational metadata only —
    // never financial ledger data. See the open `internal_*` matches below.
    function isValidInternalUser(data) {
      return (!('account_status' in data) || data.account_status in [
          'registered', 'kyc_incomplete', 'kyc_submitted', 'kyc_approved',
          'kyc_rejected', 'payment_pending', 'payment_submitted',
          'payment_verified', 'active', 'suspended'

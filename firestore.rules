rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidBaseRecord(data) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp is timestamp;
    }

    function isValidBaseRecordUpdate(data, existingData) {
      return data.keys().hasAll([
          'amount',
          'vendor_name',
          'category',
          'type',
          'status',
          'icon',
          'timestamp'
        ])
        && data.amount is number
        && data.amount > 0
        && data.amount <= 999999999999
        && data.vendor_name is string
        && data.vendor_name.size() > 0
        && data.vendor_name.size() <= 160
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 40
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 40
        && data.status in ['Completed', 'Missing Receipt', 'Pending', 'Upcoming', 'Reconciled', 'Cancelled']
        && data.icon is string
        && data.icon.size() <= 16
        && data.timestamp == existingData.timestamp;
    }

    function isValidAICaptureMetadata(data) {
      return (!('source' in data) || data.source in ['bill_scan', 'transaction_scan', 'subscription_scan'])
        && (!('created_via' in data) || data.created_via in ['ai_bill_capture', 'ai_transaction_capture', 'ai_subscription_capture'])
        && (!('extraction_status' in data) || data.extraction_status == 'reviewed')
        && (!('extraction_source' in data) || data.extraction_source is string)
        && (!('extraction_confidence' in data) || data.extraction_confidence == null || data.extraction_confidence is number)
        && (!('extraction_warnings' in data) || data.extraction_warnings is list)
        && (!('document_type' in data) || data.document_type is string)
        && (!('invoice_number' in data) || data.invoice_number == null || data.invoice_number is string)
        && (!('invoice_date' in data) || data.invoice_date is timestamp)
        && (!('raw_text_preview' in data) || data.raw_text_preview == null || (data.raw_text_preview is string && data.raw_text_preview.size() <= 500))
        && (!('source_file_name' in data) || data.source_file_name == null || data.source_file_name is string)
        && (!('source_file_mime_type' in data) || data.source_file_mime_type == null || data.source_file_mime_type is string)
        && (!('source_file_size_bytes' in data) || data.source_file_size_bytes == null || data.source_file_size_bytes is number)
        && (!('payment_reference' in data) || data.payment_reference == null || data.payment_reference is string)
        && (!('notes' in data) || data.notes == null || data.notes is string)
        && (!('billing_cycle' in data) || data.billing_cycle in ['monthly', 'annual', 'weekly', 'quarterly', 'unknown']);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll([
          'actor_uid',
          'action',
          'target_collection',
          'target_id',
          'source',
          'created_at'
        ])
        && data.actor_uid == request.auth.uid
        && data.action is string
        && data.action.size() > 0
        && data.action.size() <= 80
        && data.target_collection in [
          'transactions',
          'bills',
          'subscriptions',
          'vendors',
          'budgets',
          'budget_allocations',
          'integrations',
          'exports',
          'report_exports',
          'users',
          'onboarding',
          'bank_accounts',
          'bank_balance_snapshots',
          'bank_statement_imports',
          'documents'
        ]
        && data.target_id is string
        && data.target_id.size() <= 160
        && data.source in ['dashboard', 'ai', 'integration', 'system', 'onboarding']
        && data.created_at == request.time;
    }

    function isValidDocumentMetadata(data) {
      return data.keys().hasAll([
          'file_name',
          'file_mime_type',
          'file_size',
          'storage_path',
          'document_role',
          'source_context',
          'upload_status',
          'extraction_status',
          'review_status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'file_name',
          'file_mime_type',
          'file_size',
          'storage_path',
          'document_role',
          'source_context',
          'target_collection',
          'target_id',
          'upload_status',
          'extraction_status',
          'review_status',
          'created_at',
          'updated_at'
        ])
        && data.file_name is string
        && data.file_name.size() > 0
        && data.file_name.size() <= 240
        && data.file_mime_type in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf']
        && data.file_size is number
        && data.file_size > 0
        && data.file_size <= 5 * 1024 * 1024
        && data.storage_path is string
        && data.storage_path.size() <= 400
        && data.document_role in ['receipt', 'invoice', 'payment_proof', 'revenue_proof', 'unknown_finance_document']
        && data.source_context in ['transaction', 'revenue', 'bill', 'subscription']
        && (!('target_collection' in data) || data.target_collection == null || data.target_collection in ['transactions', 'bills', 'subscriptions'])
        && (!('target_id' in data) || data.target_id is string)
        && data.upload_status in ['pending', 'uploaded', 'failed', 'removed']
        && data.extraction_status in ['not_requested', 'pending', 'completed', 'failed']
        && data.review_status in ['not_required', 'needs_review', 'confirmed', 'rejected']
        && data.created_at is timestamp
        && data.updated_at is timestamp;
    }

    function isValidAttachedDocuments(data) {
      return !('attached_documents' in data)
        || (data.attached_documents is list && data.attached_documents.size() <= 20);
    }

    function isValidAIChat(data) {
      return data.keys().hasAll([
          'title',
          'summary',
          'last_message_preview',
          'intent',
          'source',
          'created_at',
          'updated_at',
          'last_activity_at',
          'expires_at',
          'message_count',
          'status'
        ])
        && data.keys().hasOnly([
          'title',
          'summary',
          'last_message_preview',
          'intent',
          'source',
          'created_at',
          'updated_at',
          'last_activity_at',
          'expires_at',
          'message_count',
          'status',
          'deleted_at'
        ])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.summary is string
        && data.summary.size() <= 500
        && data.last_message_preview is string
        && data.last_message_preview.size() <= 500
        && data.intent is string
        && data.intent.size() > 0
        && data.intent.size() <= 80
        && data.source == 'ai_command_center'
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && data.last_activity_at is timestamp
        && data.expires_at is timestamp
        && data.message_count is number
        && data.message_count >= 0
        && data.message_count <= 500
        && data.status in ['active', 'deleted']
        && (!('deleted_at' in data) || data.deleted_at is timestamp);
    }

    function isValidAIChatCreate(data) {
      return isValidAIChat(data)
        && data.created_at == request.time
        && data.updated_at == request.time
        && data.last_activity_at == request.time
        && data.status == 'active'
        && !('deleted_at' in data);
    }

    function isValidAIChatUpdate(data, existingData) {
      return isValidAIChat(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time
        && data.last_activity_at is timestamp;
    }

    function isValidAIChatMessage(data) {
      return data.keys().hasAll([
          'role',
          'content',
          'created_at',
          'expires_at'
        ])
        && data.keys().hasOnly([
          'role',
          'content',
          'structured_answer',
          'attachments',
          'created_at',
          'expires_at'
        ])
        && data.role in ['user', 'assistant', 'system']
        && data.content is string
        && data.content.size() <= 10000
        && (!('structured_answer' in data) || data.structured_answer == null || data.structured_answer is map)
        && (!('attachments' in data) || data.attachments is list)
        && data.created_at == request.time
        && data.expires_at is timestamp;
    }

    function isValidSettingsTimestamp(data) {
      return data.updated_at == request.time;
    }

    function isValidCompanySettings(data) {
      return data.keys().hasAll([
          'business_name',
          'business_type',
          'country',
          'entity_label',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'business_name',
          'business_type',
          'country',
          'entity_label',
          'updated_at'
        ])
        && data.business_name is string
        && data.business_name.size() > 0
        && data.business_name.size() <= 120
        && data.business_type is string
        && data.business_type.size() <= 80
        && data.country is string
        && data.country.size() > 0
        && data.country.size() <= 80
        && data.entity_label is string
        && data.entity_label.size() > 0
        && data.entity_label.size() <= 80
        && isValidSettingsTimestamp(data);
    }

    function isValidFinanceSettings(data) {
      return data.keys().hasAll([
          'currency',
          'locale',
          'timezone',
          'date_format',
          'categories',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'currency',
          'locale',
          'timezone',
          'date_format',
          'categories',
          'updated_at'
        ])
        && data.currency == 'IDR'
        && data.locale == 'id-ID'
        && data.timezone in ['Asia/Jakarta', 'Asia/Makassar', 'Asia/Jayapura']
        && data.date_format in ['DD MMM YYYY', 'DD/MM/YYYY', 'YYYY-MM-DD']
        && data.categories is list
        && data.categories.size() <= 8
        && isValidSettingsTimestamp(data);
    }

    function isValidImportRulesSettings(data) {
      return data.keys().hasAll([
          'csv_date_behavior',
          'unknown_document_route',
          'bill_scan_behavior',
          'receipt_scan_behavior',
          'payment_screenshot_behavior',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'csv_date_behavior',
          'unknown_document_route',
          'bill_scan_behavior',
          'receipt_scan_behavior',
          'payment_screenshot_behavior',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.csv_date_behavior in ['use_row_date', 'use_upload_date']
        && data.unknown_document_route == 'ai_review'
        && data.bill_scan_behavior == 'create_bill_draft'
        && data.receipt_scan_behavior == 'create_ledger_draft'
        && data.payment_screenshot_behavior == 'create_review_item'
        && data.require_confirmation_before_save == true
        && isValidSettingsTimestamp(data);
    }

    function isValidAISettings(data) {
      return data.keys().hasAll([
          'answer_style',
          'default_analysis_period',
          'show_data_quality_warnings',
          'allow_ai_suggestions',
          'allow_ai_draft_actions',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'answer_style',
          'default_analysis_period',
          'show_data_quality_warnings',
          'allow_ai_suggestions',
          'allow_ai_draft_actions',
          'require_confirmation_before_save',
          'updated_at'
        ])
        && data.answer_style in ['concise', 'practical', 'detailed']
        && data.default_analysis_period in ['current_month', 'last_month', 'last_90_days']
        && data.show_data_quality_warnings is bool
        && data.allow_ai_suggestions is bool
        && data.allow_ai_draft_actions is bool
        && data.require_confirmation_before_save == true
        && isValidSettingsTimestamp(data);
    }

    function isValidReportsSettings(data) {
      return data.keys().hasOnly([
          'arr_source',
          'recurring_revenue_category_ids',
          'updated_at'
        ])
        && data.arr_source in ['none', 'tagged_income_categories']
        && data.recurring_revenue_category_ids is list
        && data.recurring_revenue_category_ids.size() <= 32
        && isValidSettingsTimestamp(data);
    }

    function isValidWhatsAppSettings(data) {
      return data.keys().hasAll([
          'status',
          'phone_number',
          'business_display_name',
          'last_sync_at',
          'last_verified_at',
          'provider',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'status',
          'phone_number',
          'business_display_name',
          'last_sync_at',
          'last_verified_at',
          'provider',
          'updated_at'
        ])
        && data.status in ['not_connected', 'pending', 'connected']
        && (data.phone_number == null || (data.phone_number is string && data.phone_number.size() <= 32))
        && (data.business_display_name == null || (data.business_display_name is string && data.business_display_name.size() <= 120))
        && (data.last_sync_at == null || data.last_sync_at is timestamp)
        && (data.last_verified_at == null || data.last_verified_at is timestamp)
        && data.provider == 'whatsapp_cloud_api'
        && isValidSettingsTimestamp(data);
    }

    function isValidSettingsDoc(settingsDoc, data) {
      return (settingsDoc == 'company' && isValidCompanySettings(data))
        || (settingsDoc == 'finance' && isValidFinanceSettings(data))
        || (settingsDoc == 'import_rules' && isValidImportRulesSettings(data))
        || (settingsDoc == 'ai' && isValidAISettings(data))
        || (settingsDoc == 'whatsapp' && isValidWhatsAppSettings(data))
        || (settingsDoc == 'reports' && isValidReportsSettings(data));
    }

    function isValidTourId(tourId) {
      return tourId == null
        || tourId in ['overview', 'ledger', 'bills', 'fluxy_ai', 'revenue_sync', 'subscriptions'];
    }

    function isValidPlatformLearningState(data) {
      return data.keys().hasOnly([
          'dismissed',
          'dismissed_at',
          'first_rendered_at',
          'last_seen_at',
          'started_tours',
          'completed_tours',
          'skipped_tours',
          'active_tour',
          'updated_at'
        ])
        && (!('dismissed' in data) || data.dismissed is bool)
        && (!('dismissed_at' in data) || data.dismissed_at == null || data.dismissed_at is timestamp)
        && (!('first_rendered_at' in data) || data.first_rendered_at is timestamp)
        && (!('last_seen_at' in data) || data.last_seen_at is timestamp)
        && (!('started_tours' in data) || (data.started_tours is list && data.started_tours.size() <= 12))
        && (!('completed_tours' in data) || (data.completed_tours is list && data.completed_tours.size() <= 12))
        && (!('skipped_tours' in data) || (data.skipped_tours is list && data.skipped_tours.size() <= 12))
        && (!('active_tour' in data) || isValidTourId(data.active_tour))
        && (!('updated_at' in data) || data.updated_at == request.time);
    }

    function isValidBankAccount(data) {
      return data.keys().hasAll([
          'account_name',
          'bank_name',
          'currency',
          'source_type',
          'status',
          'latest_balance',
          'latest_balance_at',
          'sync_status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'account_name',
          'bank_name',
          'bank_code',
          'currency',
          'last_four',
          'source_type',
          'provider',
          'provider_account_id',
          'status',
          'latest_balance',
          'latest_balance_at',
          'sync_status',
          'last_sync_at',
          'confidence',
          'notes',
          'created_at',
          'updated_at'
        ])
        && data.account_name is string
        && data.account_name.size() > 0
        && data.account_name.size() <= 120
        && data.bank_name is string
        && data.bank_name.size() > 0
        && data.bank_name.size() <= 80
        && (!('bank_code' in data) || data.bank_code == null || (data.bank_code is string && data.bank_code.size() <= 16))
        && data.currency == 'IDR'
        && (!('last_four' in data) || data.last_four == null || (data.last_four is string && data.last_four.size() <= 4))
        && data.source_type in ['manual', 'statement_upload', 'auto_sync']
        && (!('provider' in data) || data.provider == null || (data.provider is string && data.provider.size() <= 40))
        && (!('provider_account_id' in data) || data.provider_account_id == null || (data.provider_account_id is string && data.provider_account_id.size() <= 120))
        && data.status in ['active', 'archived']
        && data.latest_balance is number
        && data.latest_balance >= 0
        && data.latest_balance <= 999999999999
        && data.latest_balance_at is timestamp
        && data.sync_status in ['manual', 'pending', 'connected', 'failed']
        && (!('last_sync_at' in data) || data.last_sync_at == null || data.last_sync_at is timestamp)
        && (!('confidence' in data) || data.confidence == null || data.confidence in ['user_entered', 'extracted', 'synced'])
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500));
    }

    function isValidBankAccountCreate(data) {
      return isValidBankAccount(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidBankAccountUpdate(data, existingData) {
      return isValidBankAccount(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    function isValidBankBalanceSnapshot(data) {
      return data.keys().hasAll([
          'bank_account_id',
          'balance',
          'currency',
          'source_type',
          'snapshot_at',
          'created_at'
        ])
        && data.keys().hasOnly([
          'bank_account_id',
          'balance',
          'currency',
          'source_type',
          'snapshot_at',
          'confidence',
          'notes',
          'created_at'
        ])
        && data.bank_account_id is string
        && data.bank_account_id.size() > 0
        && data.bank_account_id.size() <= 120
        && data.balance is number
        && data.balance >= 0
        && data.balance <= 999999999999
        && data.currency == 'IDR'
        && data.source_type in ['manual', 'statement_upload', 'auto_sync']
        && data.snapshot_at is timestamp
        && (!('confidence' in data) || data.confidence == null || data.confidence in ['user_entered', 'extracted', 'synced'])
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500))
        && data.created_at == request.time;
    }

    function isValidBudget(data) {
      return data.keys().hasAll([
          'name',
          'period_type',
          'period_start',
          'period_end',
          'currency',
          'total_budget',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'name',
          'period_type',
          'period_start',
          'period_end',
          'currency',
          'total_budget',
          'category_budgets',
          'notes',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.period_type in ['monthly', 'quarterly', 'yearly']
        && data.period_start is timestamp
        && data.period_end is timestamp
        && data.currency == 'IDR'
        && data.total_budget is number
        && data.total_budget >= 0
        && data.total_budget <= 999999999999
        && (!('category_budgets' in data) || data.category_budgets is map)
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500))
        && data.status in ['active', 'archived'];
    }

    function isValidBudgetAllocation(data) {
      return data.keys().hasAll([
          'parent_budget_id',
          'name',
          'allocated_amount',
          'scope_type',
          'scope_values',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'parent_budget_id',
          'name',
          'allocated_amount',
          'scope_type',
          'scope_values',
          'alert_threshold_percent',
          'hard_limit_enabled',
          'status',
          'created_at',
          'updated_at'
        ])
        && data.parent_budget_id is string
        && data.parent_budget_id.size() > 0
        && data.parent_budget_id.size() <= 120
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.allocated_amount is number
        && data.allocated_amount >= 0
        && data.allocated_amount <= 999999999999
        && data.scope_type == 'category'
        && data.scope_values is list
        && data.scope_values.size() > 0
        && data.scope_values.size() <= 10
        && (!('alert_threshold_percent' in data) || data.alert_threshold_percent == null || (data.alert_threshold_percent is number && data.alert_threshold_percent >= 0 && data.alert_threshold_percent <= 100))
        && (!('hard_limit_enabled' in data) || data.hard_limit_enabled is bool)
        && data.status in ['active', 'archived'];
    }

    function isValidBudgetAllocationCreate(data) {
      return isValidBudgetAllocation(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidBudgetAllocationUpdate(data, existingData) {
      return isValidBudgetAllocation(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    function isValidBillBudgetFields(data) {
      return (!('budget_id' in data) || data.budget_id == null || (data.budget_id is string && data.budget_id.size() <= 120))
        && (!('budget_allocation_id' in data) || data.budget_allocation_id == null || (data.budget_allocation_id is string && data.budget_allocation_id.size() <= 120))
        && (!('budget_match_method' in data) || data.budget_match_method == null || data.budget_match_method in ['auto', 'manual', 'rule', 'excluded', 'none'])
        && (!('budget_match_status' in data) || data.budget_match_status == null || data.budget_match_status in ['matched', 'needs_review', 'unmatched', 'excluded'])
        && (!('budget_impact_status' in data) || data.budget_impact_status == null || data.budget_impact_status in ['committed', 'released', 'converted_to_actual'])
        && (!('budget_assignment_reason' in data) || data.budget_assignment_reason == null || (data.budget_assignment_reason is string && data.budget_assignment_reason.size() <= 500))
        && (!('budget_assignment_updated_at' in data) || data.budget_assignment_updated_at == null || data.budget_assignment_updated_at is timestamp)
        && (!('budget_assignment_updated_by' in data) || data.budget_assignment_updated_by == null || (data.budget_assignment_updated_by is string && data.budget_assignment_updated_by == request.auth.uid))
        && (!('budget_exclusion_reason' in data) || data.budget_exclusion_reason == null || (data.budget_exclusion_reason is string && data.budget_exclusion_reason.size() <= 500));
    }

    function isValidTransactionBudgetFields(data) {
      return (!('budget_id' in data) || data.budget_id == null || (data.budget_id is string && data.budget_id.size() <= 120))
        && (!('budget_allocation_id' in data) || data.budget_allocation_id == null || (data.budget_allocation_id is string && data.budget_allocation_id.size() <= 120))
        && (!('budget_match_method' in data) || data.budget_match_method == null || data.budget_match_method in ['auto', 'manual', 'rule', 'excluded', 'none'])
        && (!('budget_match_status' in data) || data.budget_match_status == null || data.budget_match_status in ['matched', 'needs_review', 'unmatched', 'excluded'])
        && (!('budget_match_confidence' in data) || data.budget_match_confidence == null || (data.budget_match_confidence is number && data.budget_match_confidence >= 0 && data.budget_match_confidence <= 1))
        && (!('budget_assignment_reason' in data) || data.budget_assignment_reason == null || (data.budget_assignment_reason is string && data.budget_assignment_reason.size() <= 500))
        && (!('budget_assignment_updated_at' in data) || data.budget_assignment_updated_at == null || data.budget_assignment_updated_at is timestamp)
        && (!('budget_assignment_updated_by' in data) || data.budget_assignment_updated_by == null || (data.budget_assignment_updated_by is string && data.budget_assignment_updated_by == request.auth.uid))
        && (!('budget_exclusion_reason' in data) || data.budget_exclusion_reason == null || (data.budget_exclusion_reason is string && data.budget_exclusion_reason.size() <= 500));
    }

    function isValidBudgetCreate(data) {
      return isValidBudget(data)
        && data.created_at == request.time
        && data.updated_at == request.time;
    }

    function isValidBudgetUpdate(data, existingData) {
      return isValidBudget(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time;
    }

    function isValidBankStatementImport(data) {
      return data.keys().hasAll([
          'file_name',
          'file_mime_type',
          'file_size',
          'document_type',
          'extraction_status',
          'review_status',
          'currency',
          'row_count',
          'balance_check_status',
          'running_balance_check_status',
          'duplicate_count',
          'needs_review_count',
          'created_at',
          'updated_at'
        ])
        && data.keys().hasOnly([
          'bank_account_id',
          'file_name',
          'file_mime_type',
          'file_size',
          'storage_path',
          'document_type',
          'extraction_status',
          'review_status',
          'bank_name',
          'account_holder',
          'account_number_masked',
          'currency',
          'statement_start_date',
          'statement_end_date',
          'opening_balance',
          'closing_balance',
          'total_debit',
          'total_credit',
          'row_count',
          'balance_check_status',
          'running_balance_check_status',
          'duplicate_count',
          'needs_review_count',
          'created_at',
          'updated_at',
          'confirmed_at',
          'imported_at'
        ])
        && data.file_name is string
        && data.file_name.size() > 0
        && data.file_name.size() <= 240
        && data.file_mime_type is string
        && data.file_mime_type.size() <= 160
        && data.file_size is number
        && data.file_size >= 0
        && data.file_size <= 10 * 1024 * 1024
        && (!('storage_path' in data) || data.storage_path == null || (data.storage_path is string && data.storage_path.size() <= 400))
        && data.document_type == 'bank_statement'
        && data.extraction_status in ['pending', 'processing', 'completed', 'failed']
        && data.review_status in ['draft', 'needs_review', 'ready_to_import', 'imported', 'rejected']
        && (!('bank_account_id' in data) || data.bank_account_id == null || (data.bank_account_id is string && data.bank_account_id.size() <= 120))
        && (!('bank_name' in data) || data.bank_name == null || (data.bank_name is string && data.bank_name.size() <= 80))
        && (!('account_holder' in data) || data.account_holder == null || (data.account_holder is string && data.account_holder.size() <= 160))
        && (!('account_number_masked' in data) || data.account_number_masked == null || (data.account_number_masked is string && data.account_number_masked.size() <= 32))
        && data.currency == 'IDR'
        && (!('statement_start_date' in data) || data.statement_start_date == null || data.statement_start_date is timestamp)
        && (!('statement_end_date' in data) || data.statement_end_date == null || data.statement_end_date is timestamp)
        && (!('opening_balance' in data) || data.opening_balance == null || data.opening_balance is number)
        && (!('closing_balance' in data) || data.closing_balance == null || data.closing_balance is number)
        && (!('total_debit' in data) || data.total_debit == null || data.total_debit is number)
        && (!('total_credit' in data) || data.total_credit == null || data.total_credit is number)
        && data.row_count is number
        && data.row_count >= 0
        && data.balance_check_status in ['passed', 'failed', 'unavailable']
        && data.running_balance_check_status in ['passed', 'failed', 'unavailable']
        && data.duplicate_count is number
        && data.duplicate_count >= 0
        && data.needs_review_count is number
        && data.needs_review_count >= 0
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && (!('confirmed_at' in data) || data.confirmed_at == null || data.confirmed_at is timestamp)
        && (!('imported_at' in data) || data.imported_at == null || data.imported_at is timestamp);
    }

    function isValidBankStatementImportCreate(userId, data) {
      return isValidBankStatementImport(data)
        && data.created_at == request.time
        && data.updated_at == request.time
        && data.review_status == 'draft'
        && data.extraction_status == 'pending'
        && (!('storage_path' in data) || data.storage_path == null
              || data.storage_path.matches('users/' + userId + '/bank_statement_imports/.*'));
    }

    function isValidBankStatementImportUpdate(userId, data, existingData) {
      return isValidBankStatementImport(data)
        && data.created_at == existingData.created_at
        && data.updated_at == request.time
        && data.file_name == existingData.file_name
        && data.file_mime_type == existingData.file_mime_type
        && data.file_size == existingData.file_size
        && (!('storage_path' in data) || data.storage_path == null
              || data.storage_path.matches('users/' + userId + '/bank_statement_imports/.*'));
    }

    function isValidBankStatementRow(data) {
      return data.keys().hasOnly([
          'row_index',
          'transaction_date',
          'posting_date',
          'description_raw',
          'debit',
          'credit',
          'running_balance',
          'suggested_vendor_name',
          'suggested_category',
          'suggested_type',
          'match_status',
          'matched_transaction_id',
          'confidence',
          'selected_for_import',
          'review_status',
          'created_transaction_id',
          'created_at'
        ])
        && data.row_index is number
        && data.row_index >= 0
        && (!('transaction_date' in data) || data.transaction_date == null || data.transaction_date is timestamp)
        && (!('posting_date' in data) || data.posting_date == null || data.posting_date is timestamp)
        && (!('description_raw' in data) || data.description_raw == null || (data.description_raw is string && data.description_raw.size() <= 500))
        && (!('debit' in data) || data.debit == null || data.debit is number)
        && (!('credit' in data) || data.credit == null || data.credit is number)
        && (!('running_balance' in data) || data.running_balance == null || data.running_balance is number)
        && (!('suggested_vendor_name' in data) || data.suggested_vendor_name == null || (data.suggested_vendor_name is string && data.suggested_vendor_name.size() <= 160))
        && (!('suggested_category' in data) || data.suggested_category == null || (data.suggested_category is string && data.suggested_category.size() <= 80))
        && (!('suggested_type' in data) || data.suggested_type == null || (data.suggested_type is string && data.suggested_type.size() <= 40))
        && (!('match_status' in data) || data.match_status in ['new', 'possible_duplicate', 'matched_existing', 'ignored', 'needs_review'])
        && (!('matched_transaction_id' in data) || data.matched_transaction_id == null || (data.matched_transaction_id is string && data.matched_transaction_id.size() <= 120))
        && (!('confidence' in data) || data.confidence == null || data.confidence is number)
        && (!('selected_for_import' in data) || data.selected_for_import is bool)
        && (!('review_status' in data) || data.review_status in ['pending', 'confirmed', 'ignored'])
        && (!('created_transaction_id' in data) || data.created_transaction_id == null || (data.created_transaction_id is string && data.created_transaction_id.size() <= 120))
        && data.created_at is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'created_at',
            'receipt_url',
            'attached_documents',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'payment_reference',
            'notes',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_match_confidence',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason'
          ])
          && isValidBaseRecord(request.resource.data)
          && (!('created_at' in request.resource.data) || request.resource.data.created_at == request.time)
          && (!('receipt_url' in request.resource.data) || request.resource.data.receipt_url is string)
          && isValidTransactionBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'created_at',
            'receipt_url',
            'attached_documents',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'payment_reference',
            'notes',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_match_confidence',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason'
          ])
          && isValidBaseRecordUpdate(request.resource.data, resource.data)
          && isValidTransactionBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow delete: if false;
      }

      match /bills/{billId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'due_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'payment_status',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'attached_documents',
            'invoice_status',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_impact_status',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason'
          ])
          && isValidBaseRecord(request.resource.data)
          && (!('due_date' in request.resource.data) || request.resource.data.due_date is timestamp)
          && (!('payment_status' in request.resource.data) || request.resource.data.payment_status in ['unpaid', 'paid', 'overdue', 'unknown'])
          && (!('invoice_status' in request.resource.data) || request.resource.data.invoice_status in ['attached'])
          && isValidBillBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'due_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'payment_status',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'attached_documents',
            'invoice_status',
            'budget_id',
            'budget_allocation_id',
            'budget_match_method',
            'budget_match_status',
            'budget_impact_status',
            'budget_assignment_reason',
            'budget_assignment_updated_at',
            'budget_assignment_updated_by',
            'budget_exclusion_reason'
          ])
          && isValidBaseRecordUpdate(request.resource.data, resource.data)
          && (!('due_date' in request.resource.data) || request.resource.data.due_date is timestamp)
          && (!('payment_status' in request.resource.data) || request.resource.data.payment_status in ['unpaid', 'paid', 'overdue', 'unknown'])
          && (!('invoice_status' in request.resource.data) || request.resource.data.invoice_status in ['attached'])
          && isValidBillBudgetFields(request.resource.data)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow delete: if false;
      }

      match /subscriptions/{subscriptionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'renewal_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'billing_cycle',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'notes',
            'attached_documents'
          ])
          && isValidBaseRecord(request.resource.data)
          && (!('renewal_date' in request.resource.data) || request.resource.data.renewal_date is timestamp)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'amount',
            'vendor_name',
            'category',
            'type',
            'status',
            'icon',
            'timestamp',
            'renewal_date',
            'source',
            'created_via',
            'extraction_status',
            'extraction_source',
            'extraction_confidence',
            'extraction_warnings',
            'document_type',
            'invoice_number',
            'invoice_date',
            'billing_cycle',
            'raw_text_preview',
            'source_file_name',
            'source_file_mime_type',
            'source_file_size_bytes',
            'notes',
            'attached_documents'
          ])
          && isValidBaseRecordUpdate(request.resource.data, resource.data)
          && (!('renewal_date' in request.resource.data) || request.resource.data.renewal_date is timestamp)
          && isValidAttachedDocuments(request.resource.data)
          && isValidAICaptureMetadata(request.resource.data);
        allow delete: if false;
      }

      match /report_exports/{exportId} {
        // Metadata for a confirmed Reports & Exports run. Stores period,
        // formats, included sections, record counts, warning counts, and
        // (for YTD/YoY) the resolved report scope. Must never contain
        // row-level financial data or CSV content.
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'report_type',
            'report_scope',
            'period_start',
            'period_end',
            'formats',
            'status',
            'included_sections',
            'record_counts',
            'warning_counts',
            'limitations',
            'created_at',
            'created_by'
          ])
          && request.resource.data.report_type is string
          && request.resource.data.report_type.size() > 0
          && request.resource.data.report_type.size() <= 80
          && request.resource.data.created_by == request.auth.uid
          && request.resource.data.created_at == request.time
          && request.resource.data.formats is list
          && request.resource.data.status is string
          && request.resource.data.included_sections is list
          && request.resource.data.record_counts is map
          && request.resource.data.warning_counts is map
          && request.resource.data.limitations is list
          && (!('report_scope' in request.resource.data) || request.resource.data.report_scope is map);
        allow update, delete: if false;
      }

      match /audit_logs/{auditLogId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'actor_uid',
            'actor_role',
            'action',
            'target_collection',
            'target_id',
            'before',
            'after',
            'reason',
            'source',
            'created_at'
          ])
          && isValidAuditLog(request.resource.data);
        allow update, delete: if false;
      }

      match /documents/{documentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidDocumentMetadata(request.resource.data)
          && request.resource.data.created_at == request.time
          && request.resource.data.updated_at == request.time
          && request.resource.data.storage_path.matches('users/' + userId + '/documents/.*');
        allow update: if isOwner(userId)
          && isValidDocumentMetadata(request.resource.data)
          && request.resource.data.created_at == resource.data.created_at
          && request.resource.data.updated_at == request.time
          && request.resource.data.storage_path == resource.data.storage_path;
        allow delete: if false;
      }

      match /ai_chats/{chatId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidAIChatCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidAIChatUpdate(request.resource.data, resource.data);
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidAIChatMessage(request.resource.data);
          allow update, delete: if false;
        }
      }

      match /settings/{settingsDoc} {
        allow read: if isOwner(userId)
          && settingsDoc in ['company', 'finance', 'import_rules', 'ai', 'whatsapp', 'reports'];
        allow create, update: if isOwner(userId)
          && isValidSettingsDoc(settingsDoc, request.resource.data);
        allow delete: if false;
      }

      match /onboarding/{onboardingDoc} {
        allow read: if isOwner(userId)
          && onboardingDoc in ['progress', 'profile', 'documents'];
        allow create, update: if isOwner(userId)
          && onboardingDoc in ['progress', 'profile', 'documents'];
        allow delete: if false;
      }

      match /bank_accounts/{bankAccountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBankAccountCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidBankAccountUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      match /bank_balance_snapshots/{snapshotId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBankBalanceSnapshot(request.resource.data);
        allow update, delete: if false;
      }

      match /bank_statement_imports/{importId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBankStatementImportCreate(userId, request.resource.data);
        allow update: if isOwner(userId)
          && isValidBankStatementImportUpdate(userId, request.resource.data, resource.data);
        allow delete: if false;

        match /rows/{rowId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidBankStatementRow(request.resource.data)
            && request.resource.data.created_at == request.time;
          allow update: if isOwner(userId)
            && isValidBankStatementRow(request.resource.data)
            && request.resource.data.created_at == resource.data.created_at;
          allow delete: if false;
        }
      }

      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBudgetCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidBudgetUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      match /budget_allocations/{allocationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidBudgetAllocationCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidBudgetAllocationUpdate(request.resource.data, resource.data);
        allow delete: if false;
      }

      match /platform_learning/{learningDoc} {
        allow read: if isOwner(userId) && learningDoc == 'state';
        allow create, update: if isOwner(userId)
          && learningDoc == 'state'
          && isValidPlatformLearningState(request.resource.data);
        allow delete: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

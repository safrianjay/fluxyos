# FLUXyOS ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your secrets

# APP CONFIG
PORT=8000
DEBUG=False
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-change-me

# DATABASE CONFIG
DATABASE_URL=postgresql://user:password@localhost:5432/fluxyos

# API KEYS
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...

# FIREBASE
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-web-api-key

# SECURITY
ALLOWED_ORIGINS=https://fluxyos.com,https://www.fluxyos.com

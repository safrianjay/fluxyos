# FLUXyOS ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your secrets

# APP CONFIG
PORT=8000
DEBUG=True
SECRET_KEY=your-super-secret-key-change-me

# DATABASE CONFIG
DATABASE_URL=postgresql://user:password@localhost:5432/fluxyos

# API KEYS
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...

# SECURITY
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

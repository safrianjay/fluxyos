# Copy to functions/.env (gitignored) for local/deploy config.
# These are NON-SECRET. The Resend API key is a Secret Manager secret, NOT here.

# Sender identity — domain MUST be verified in Resend.
EMAIL_FROM="FluxyOS <notifications@fluxyos.com>"
EMAIL_REPLY_TO="support@fluxyos.com"

# Where CTA links point.
APP_BASE_URL="https://fluxyos.com"

# Fallback email language when a user has no saved finance locale: "en" or "id".
DEFAULT_LOCALE="en"

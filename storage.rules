rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function hasTrialStorageEntitlement(userId) {
      return firestore.exists(/databases/(default)/documents/users/$(userId)/billing_subscription/current)
        && (
          firestore.get(/databases/(default)/documents/users/$(userId)/billing_subscription/current).data.plan_id == 'trial'
          || firestore.get(/databases/(default)/documents/users/$(userId)/billing_subscription/current).data.status in [
            'trialing',
            'awaiting_payment',
            'pending_verification',
            'payment_failed',
            'expired'
          ]
        );
    }

    function respectsTrialStorageSingleFileLimit(userId) {
      return !hasTrialStorageEntitlement(userId)
        || request.resource.size <= 5 * 1024 * 1024;
    }

    // Workspace membership for shared finance storage (documents, bank statements).
    // Mirrors firestore.rules isMember(): active member of the workspace. The
    // workspace id equals the owner's uid, so trial limits read the owner's billing.
    function isWorkspaceMember(workspaceId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.status == 'active';
    }

    match /users/{userId}/receipts/{filename} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size <= 1 * 1024 * 1024
                    && request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp'];
      allow delete: if false;
    }
    match /users/{userId}/documents/{documentId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && respectsTrialStorageSingleFileLimit(userId)
                    && request.resource.size <= 5 * 1024 * 1024
                    && request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
      allow delete: if false;
    }
    match /users/{userId}/bank_statement_imports/{importId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && respectsTrialStorageSingleFileLimit(userId)
                    && request.resource.size <= 10 * 1024 * 1024
                    && request.resource.contentType in [
                        'application/pdf',
                        'text/csv',
                        'application/csv',
                        'application/vnd.ms-excel',
                        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    ];
      allow delete: if false;
    }
    // Workspace-scoped finance storage (shared across team members). Mirrors the
    // user-scoped document / bank-statement rules above, gated by workspace
    // membership instead of uid ownership. See firestore.rules §workspaces.
    match /workspaces/{workspaceId}/documents/{documentId}/{fileName} {
      allow read:   if isWorkspaceMember(workspaceId);
      allow write:  if isWorkspaceMember(workspaceId)
                    && respectsTrialStorageSingleFileLimit(workspaceId)
                    && request.resource.size <= 5 * 1024 * 1024
                    && request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
      allow delete: if false;
    }
    match /workspaces/{workspaceId}/bank_statement_imports/{importId}/{fileName} {
      allow read:   if isWorkspaceMember(workspaceId);
      allow write:  if isWorkspaceMember(workspaceId)
                    && respectsTrialStorageSingleFileLimit(workspaceId)
                    && request.resource.size <= 10 * 1024 * 1024
                    && request.resource.contentType in [
                        'application/pdf',
                        'text/csv',
                        'application/csv',
                        'application/vnd.ms-excel',
                        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    ];
      allow delete: if false;
    }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
